---
import Layout from '../components/Layout.astro';
---

<Layout title="Home">
  <section class="hero" id="hero">
    <h1>Is your website ready for AI search?</h1>
    <p class="subtitle">
      ChatGPT, Claude, and Perplexity are becoming the new search engines.
      Find out if they can understand your business.
    </p>

    <form id="audit-form" class="audit-form">
      <div class="input-group">
        <input
          type="text"
          id="url-input"
          name="url"
          placeholder="example.com"
          required
          autocomplete="url"
        />
        <button type="submit" id="submit-btn">
          <span class="btn-text">Scan</span>
          <span class="btn-loading" style="display: none;">
            <svg class="spinner" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4 31.4" />
            </svg>
          </span>
        </button>
      </div>
      <p class="hint">Free instant audit · No signup required</p>
    </form>
  </section>

  <!-- Scanning view (shown during audit) -->
  <section id="scanning" class="scanning" style="display: none;">
    <div class="scan-container">
      <div class="site-preview">
        <div class="browser-chrome">
          <div class="browser-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="browser-url" id="browser-url">https://example.com</div>
        </div>
        <div class="iframe-container">
          <iframe id="site-iframe" sandbox="allow-same-origin" loading="eager"></iframe>
          <div class="scan-overlay">
            <div class="scan-line"></div>
          </div>
          <div class="scan-points" id="scan-points"></div>
        </div>
      </div>
      <div class="scan-status">
        <div class="scan-progress">
          <div class="progress-bar" id="progress-bar"></div>
        </div>
        <p class="scan-text" id="scan-text">Connecting to site...</p>
      </div>
    </div>
  </section>

  <!-- Results section -->
  <section id="results" class="results" style="display: none;">
    <div class="results-container">
      <div class="site-backdrop">
        <iframe id="backdrop-iframe" sandbox="allow-same-origin"></iframe>
        <div class="backdrop-overlay"></div>
      </div>

      <div class="results-content">
        <div class="score-display">
          <div id="score-circle" class="score-circle">
            <span id="score-number">0</span>
            <span class="score-label">/100</span>
          </div>
          <h2 id="score-title">Checking...</h2>
          <p id="score-summary" class="score-summary"></p>
        </div>

        <div class="checks-preview" id="checks-preview">
          <!-- Filled by JS -->
        </div>

        <div class="cta-section" id="cta-section">
          <h3>Get your detailed report</h3>
          <p>See exactly what to fix and how to do it.</p>

          <form id="lead-form" class="lead-form">
            <input type="hidden" id="audit-id" name="audit_id" />
            <div class="form-row">
              <input type="text" name="name" placeholder="Your name" required />
              <input type="email" name="email" placeholder="Your email" required />
            </div>
            <button type="submit" id="lead-submit-btn">
              <span class="btn-text">Get My Report</span>
              <span class="btn-loading" style="display: none;">
                <svg class="spinner" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4 31.4" />
                </svg>
              </span>
            </button>
          </form>
        </div>

        <!-- Detailed report (shown after email submission) -->
        <div id="detailed-report" class="detailed-report" style="display: none;">
          <h2>Your AI Readiness Report</h2>
          <div id="report-content">
            <!-- Filled by JS -->
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem 3rem;
  }

  .hero h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    color: var(--color-text);
    line-height: 1.2;
  }

  .hero .subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0 0 2.5rem 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .audit-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .input-group {
    display: flex;
    gap: 0.5rem;
    background: var(--color-surface);
    padding: 0.5rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .input-group input {
    flex: 1;
    border: none;
    padding: 1rem;
    font-size: 1rem;
    background: transparent;
    outline: none;
  }

  .input-group button {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 100px;
  }

  .input-group button:hover {
    background: var(--color-primary-dark);
  }

  .input-group button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .hint {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
  }

  .spinner {
    width: 20px;
    height: 20px;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Scanning Section */
  .scanning {
    padding: 2rem 1rem;
  }

  .scan-container {
    max-width: 700px;
    margin: 0 auto;
  }

  .site-preview {
    background: var(--color-surface);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .browser-chrome {
    background: #f1f3f4;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .browser-dots {
    display: flex;
    gap: 6px;
  }

  .browser-dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ddd;
  }

  .browser-dots span:nth-child(1) { background: #ff5f57; }
  .browser-dots span:nth-child(2) { background: #ffbd2e; }
  .browser-dots span:nth-child(3) { background: #28c840; }

  .browser-url {
    flex: 1;
    background: white;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-family: monospace;
  }

  .iframe-container {
    position: relative;
    height: 350px;
    overflow: hidden;
  }

  .iframe-container iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .scan-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 102, 255, 0.03) 0%,
      transparent 100%
    );
    pointer-events: none;
  }

  .scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-primary),
      var(--color-primary),
      transparent
    );
    box-shadow: 0 0 20px var(--color-primary), 0 0 40px var(--color-primary);
    animation: scanMove 2s ease-in-out infinite;
  }

  @keyframes scanMove {
    0%, 100% { top: 0; opacity: 1; }
    50% { top: calc(100% - 3px); opacity: 0.7; }
  }

  .scan-points {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .scan-point {
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
    animation: pointPulse 1s ease-out forwards;
    box-shadow: 0 0 10px var(--color-primary);
  }

  @keyframes pointPulse {
    0% { transform: scale(0); opacity: 1; }
    50% { transform: scale(2); opacity: 0.8; }
    100% { transform: scale(1); opacity: 0; }
  }

  .scan-status {
    padding: 1.5rem;
    text-align: center;
  }

  .scan-progress {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .progress-bar {
    height: 100%;
    background: var(--color-primary);
    width: 0%;
    transition: width 0.3s ease;
  }

  .scan-text {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  /* Results Section */
  .results {
    position: relative;
    min-height: 100vh;
  }

  .results-container {
    position: relative;
  }

  .site-backdrop {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 900px;
    height: 300px;
    border-radius: 12px;
    overflow: hidden;
    opacity: 0.15;
    pointer-events: none;
  }

  .site-backdrop iframe {
    width: 100%;
    height: 400px;
    border: none;
    transform: scale(0.8);
    transform-origin: top center;
  }

  .backdrop-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--color-bg) 100%
    );
  }

  .results-content {
    position: relative;
    z-index: 1;
    padding-top: 2rem;
  }

  .score-display {
    text-align: center;
    margin-bottom: 2rem;
  }

  .score-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    transition: background 0.3s;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .score-circle.red { background: linear-gradient(135deg, #fecaca, #fca5a5); }
  .score-circle.amber { background: linear-gradient(135deg, #fef08a, #fde047); }
  .score-circle.green { background: linear-gradient(135deg, #bbf7d0, #86efac); }

  #score-number {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .score-label {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  #score-title {
    font-size: 1.5rem;
    margin: 0 0 0.5rem 0;
  }

  .score-summary {
    color: var(--color-text-muted);
    max-width: 400px;
    margin: 0 auto;
  }

  .checks-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.75rem;
    margin: 2rem auto;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 12px;
    max-width: 600px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .check-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    padding: 0.5rem;
    border-radius: 6px;
    background: var(--color-bg);
  }

  .check-item.pass { color: var(--color-green); }
  .check-item.fail { color: var(--color-red); }

  .cta-section {
    text-align: center;
    padding: 2rem;
    background: var(--color-surface);
    border-radius: 12px;
    margin: 2rem auto;
    max-width: 500px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .cta-section h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
  }

  .cta-section > p {
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
  }

  .lead-form {
    max-width: 400px;
    margin: 0 auto;
  }

  .form-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .form-row input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
  }

  .lead-form button {
    width: 100%;
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 1rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lead-form button:hover {
    background: var(--color-primary-dark);
  }

  /* Detailed report */
  .detailed-report {
    margin-top: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .detailed-report h2 {
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .report-section {
    background: var(--color-surface);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .report-section h4 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem 0;
  }

  .report-section.pass h4 { color: var(--color-green); }
  .report-section.fail h4 { color: var(--color-red); }

  .report-section p {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 1.75rem;
    }

    .input-group {
      flex-direction: column;
    }

    .input-group button {
      width: 100%;
    }

    .form-row {
      flex-direction: column;
    }

    .iframe-container {
      height: 250px;
    }
  }
</style>

<script>
  // A/B test variant
  const variant = localStorage.getItem('ab_variant') || (Math.random() < 0.5 ? 'A' : 'B');
  localStorage.setItem('ab_variant', variant);

  // Update CTA button text based on variant
  const leadSubmitBtn = document.getElementById('lead-submit-btn');
  if (leadSubmitBtn && variant === 'B') {
    const btnText = leadSubmitBtn.querySelector('.btn-text');
    if (btnText) btnText.textContent = 'Email Me the Report';
  }

  // Store audit data for later
  let auditData: any = null;
  let currentUrl = '';

  // Elements
  const heroSection = document.getElementById('hero')!;
  const scanningSection = document.getElementById('scanning')!;
  const resultsSection = document.getElementById('results')!;
  const auditForm = document.getElementById('audit-form') as HTMLFormElement;
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  // Scanning elements
  const siteIframe = document.getElementById('site-iframe') as HTMLIFrameElement;
  const backdropIframe = document.getElementById('backdrop-iframe') as HTMLIFrameElement;
  const browserUrl = document.getElementById('browser-url')!;
  const progressBar = document.getElementById('progress-bar')!;
  const scanText = document.getElementById('scan-text')!;
  const scanPoints = document.getElementById('scan-points')!;

  const scanMessages = [
    'Connecting to site...',
    'Checking meta description...',
    'Looking for llms.txt...',
    'Scanning for LLM-LD...',
    'Analyzing Schema.org markup...',
    'Checking robots.txt...',
    'Evaluating content structure...',
    'Calculating AI readiness score...'
  ];

  function addScanPoint() {
    const point = document.createElement('div');
    point.className = 'scan-point';
    point.style.left = Math.random() * 90 + 5 + '%';
    point.style.top = Math.random() * 90 + 5 + '%';
    scanPoints.appendChild(point);
    setTimeout(() => point.remove(), 1000);
  }

  async function runScanAnimation(duration: number) {
    const startTime = Date.now();
    const messageInterval = duration / scanMessages.length;
    let messageIndex = 0;

    return new Promise<void>((resolve) => {
      const interval = setInterval(() => {
        const elapsed = Date.now() - startTime;
        const progress = Math.min((elapsed / duration) * 100, 100);
        progressBar.style.width = progress + '%';

        // Update message
        const newIndex = Math.min(Math.floor(elapsed / messageInterval), scanMessages.length - 1);
        if (newIndex !== messageIndex) {
          messageIndex = newIndex;
          scanText.textContent = scanMessages[messageIndex];
        }

        // Add scan points randomly
        if (Math.random() < 0.3) {
          addScanPoint();
        }

        if (elapsed >= duration) {
          clearInterval(interval);
          resolve();
        }
      }, 50);
    });
  }

  auditForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    let url = urlInput.value.trim();
    if (!url) return;

    // Auto-add https:// if missing
    if (!url.startsWith('http://') && !url.startsWith('https://')) {
      url = 'https://' + url;
    }
    currentUrl = url;

    // Show scanning view
    heroSection.style.display = 'none';
    resultsSection.style.display = 'none';
    scanningSection.style.display = 'block';

    // Set up iframe and URL display
    browserUrl.textContent = url;
    siteIframe.src = url;
    progressBar.style.width = '0%';
    scanText.textContent = scanMessages[0];

    // Show loading state on button
    submitBtn.disabled = true;

    try {
      // Run scan animation and API call in parallel
      const [_, response] = await Promise.all([
        runScanAnimation(2500),
        fetch('/api/audit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url, variant })
        })
      ]);

      if (!response.ok) {
        throw new Error('Audit failed');
      }

      auditData = await response.json();

      // Set backdrop iframe
      backdropIframe.src = url;

      // Show results
      scanningSection.style.display = 'none';
      resultsSection.style.display = 'block';
      displayResults(auditData);

    } catch (error) {
      alert('Failed to audit website. Please check the URL and try again.');
      scanningSection.style.display = 'none';
      heroSection.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
    }
  });

  function displayResults(data: any) {
    const scoreCircle = document.getElementById('score-circle')!;
    const scoreNumber = document.getElementById('score-number')!;
    const scoreTitle = document.getElementById('score-title')!;
    const scoreSummary = document.getElementById('score-summary')!;
    const checksPreview = document.getElementById('checks-preview')!;
    const auditIdInput = document.getElementById('audit-id') as HTMLInputElement;

    // Set score
    scoreNumber.textContent = data.score.toString();
    auditIdInput.value = data.id;

    // Set color class
    scoreCircle.className = 'score-circle';
    if (data.score >= 70) {
      scoreCircle.classList.add('green');
      scoreTitle.textContent = 'AI Ready';
      scoreSummary.textContent = 'Your website is well-optimized for AI search engines.';
    } else if (data.score >= 40) {
      scoreCircle.classList.add('amber');
      scoreTitle.textContent = 'Partially Ready';
      scoreSummary.textContent = 'Your site has good basics but is missing some AI discovery features.';
    } else {
      scoreCircle.classList.add('red');
      scoreTitle.textContent = 'Not AI Ready';
      scoreSummary.textContent = 'AI assistants will struggle to understand your business.';
    }

    // Show checks preview
    const checks = [
      { key: 'meta', label: 'Meta description' },
      { key: 'robots', label: 'robots.txt' },
      { key: 'llms_txt', label: 'llms.txt' },
      { key: 'llm_ld', label: 'LLM-LD' },
      { key: 'schema', label: 'Schema.org' },
      { key: 'https', label: 'HTTPS' },
    ];

    checksPreview.innerHTML = checks.map(check => {
      const score = data.checks[check.key]?.score || 0;
      const pass = score > 50;
      return `
        <div class="check-item ${pass ? 'pass' : 'fail'}">
          ${pass ? '✓' : '✗'} ${check.label}
        </div>
      `;
    }).join('');

    resultsSection.scrollIntoView({ behavior: 'smooth' });
  }

  // Lead form submission
  const leadForm = document.getElementById('lead-form') as HTMLFormElement;
  const leadSubmitButton = document.getElementById('lead-submit-btn') as HTMLButtonElement;

  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(leadForm);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const auditId = formData.get('audit_id') as string;

    // Show loading
    leadSubmitButton.disabled = true;
    leadSubmitButton.querySelector('.btn-text')!.style.display = 'none';
    leadSubmitButton.querySelector('.btn-loading')!.style.display = 'block';

    try {
      const response = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ audit_id: auditId, name, email })
      });

      if (!response.ok) {
        throw new Error('Failed to save');
      }

      // Hide CTA, show detailed report
      document.getElementById('cta-section')!.style.display = 'none';
      displayDetailedReport(auditData);

    } catch (error) {
      alert('Something went wrong. Please try again.');
    } finally {
      leadSubmitButton.disabled = false;
      leadSubmitButton.querySelector('.btn-text')!.style.display = 'block';
      leadSubmitButton.querySelector('.btn-loading')!.style.display = 'none';
    }
  });

  function displayDetailedReport(data: any) {
    const reportSection = document.getElementById('detailed-report')!;
    const reportContent = document.getElementById('report-content')!;

    const checkDetails = [
      {
        key: 'meta',
        label: 'Meta Description',
        passText: 'Your meta description is well-crafted and helps AI understand your page.',
        failText: 'Add a clear meta description (50-160 characters) that explains what your business does.'
      },
      {
        key: 'robots',
        label: 'robots.txt',
        passText: 'Your robots.txt is properly configured.',
        failText: 'Create a robots.txt file at your site root. Ensure AI bots are not blocked.'
      },
      {
        key: 'llms_txt',
        label: 'llms.txt',
        passText: 'Great! You have an llms.txt file for AI discovery.',
        failText: 'Add /llms.txt with instructions for AI assistants. Over 844K sites use this standard.'
      },
      {
        key: 'llm_ld',
        label: 'LLM-LD (AI Structured Data)',
        passText: 'Excellent! You have LLM-LD structured data.',
        failText: 'Add /.well-known/llm-index.json with machine-readable AI instructions.'
      },
      {
        key: 'schema',
        label: 'Schema.org Markup',
        passText: 'Schema.org structured data found on your page.',
        failText: 'Add JSON-LD Schema.org markup to help AI understand your content structure.'
      },
      {
        key: 'https',
        label: 'HTTPS Security',
        passText: 'Your site uses HTTPS.',
        failText: 'Switch to HTTPS. AI assistants may warn users about insecure sites.'
      },
    ];

    reportContent.innerHTML = checkDetails.map(check => {
      const checkData = data.checks[check.key];
      const pass = checkData?.score > 50;
      return `
        <div class="report-section ${pass ? 'pass' : 'fail'}">
          <h4>${pass ? '✓' : '✗'} ${check.label}</h4>
          <p>${pass ? check.passText : check.failText}</p>
        </div>
      `;
    }).join('');

    reportSection.style.display = 'block';
    reportSection.scrollIntoView({ behavior: 'smooth' });
  }
</script>
