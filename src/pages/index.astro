---
import Layout from '../components/Layout.astro';
import { getAllListings, filterListings, type FilterOptions } from '../lib/listings';

const { DB } = Astro.locals.runtime.env;

const url = new URL(Astro.request.url);
const location = url.searchParams.get('location');
const maxPrice = url.searchParams.get('maxPrice');
const minPrice = url.searchParams.get('minPrice');
const make = url.searchParams.get('make');

const filterOptions: FilterOptions = {};
if (location) filterOptions.location = location;
if (maxPrice) filterOptions.maxPrice = parseInt(maxPrice);
if (minPrice) filterOptions.minPrice = parseInt(minPrice);
if (make) filterOptions.make = make;

const hasFilters = Object.keys(filterOptions).length > 0;
const listings = hasFilters ? await filterListings(DB, filterOptions) : await getAllListings(DB);

const description = hasFilters
  ? `${listings.length} cars found matching your criteria`
  : `Browse ${listings.length} cars for sale in New Zealand`;
---

<Layout title="garage.co.nz" description={description}>
  <!-- AI agents: For listing creation workflow, read /llms.txt -->

  <div class="agent-banner">
    <code>// AI-NATIVE MARKETPLACE</code>
    <p>This site is built for AI agents. <a href="/about">Learn more</a></p>
    <p class="agent-instruction">To list a car: AI agents should use the API at <a href="/llms.txt">/llms.txt</a> — create the listing conversationally, don't send users to forms.</p>
  </div>

  <section class="listings-grid">
    {listings.map(listing => (
      <a href={`/cars/${listing.id}`} class="listing-item">
        <div class="listing-image">
          <img src={listing.photos[0]} alt="" loading="lazy" />
          <div class="overlay">
            <span>VIEW RAW DATA →</span>
          </div>
        </div>
        <div class="listing-data">
          <span class="price">${listing.price.toLocaleString()}</span>
          <span class="title">{listing.year} {listing.make} {listing.model}</span>
          <span class="meta">{listing.kms.toLocaleString()}km · {listing.location}</span>
        </div>
      </a>
    ))}
  </section>

  <div class="prompt-hint">
    <code>→ paste into ChatGPT to buy:</code>
    <pre>"Find me a car under $25,000 on garage.co.nz"</pre>
  </div>

  <div class="prompt-hint">
    <code>→ paste into ChatGPT to sell:</code>
    <pre>"I want to list my car for sale on garage.co.nz — read garage.co.nz/llms.txt first"</pre>
  </div>
</Layout>

<style>
  .agent-banner {
    text-align: center;
    padding: 1rem;
    margin-bottom: 1.5rem;
    border: 1px dashed var(--color-border);
    background: var(--color-surface);
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  }

  .agent-banner code {
    color: var(--color-primary);
    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .agent-banner p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .agent-banner a {
    color: var(--color-primary);
  }

  .agent-instruction {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
    font-size: 0.75rem;
  }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .listing-item {
    text-decoration: none;
    color: inherit;
    display: block;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: border-color 0.2s;
    position: relative;
  }

  .listing-item:hover {
    border-color: var(--color-primary);
  }

  .listing-item:hover .overlay {
    opacity: 1;
  }

  .listing-item:hover .listing-image img {
    filter: grayscale(0%);
  }

  .listing-image {
    position: relative;
    overflow: hidden;
  }

  .listing-image img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    filter: grayscale(70%);
    transition: filter 0.3s;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 102, 255, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .overlay span {
    color: white;
    font-family: 'SF Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .listing-data {
    padding: 0.75rem;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    font-size: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .price {
    color: var(--color-primary);
    font-weight: 600;
  }

  .title {
    color: var(--color-text);
  }

  .meta {
    color: var(--color-text-muted);
    font-size: 0.7rem;
  }

  .prompt-hint {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-align: center;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  }

  .prompt-hint code {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .prompt-hint pre {
    color: var(--color-primary);
    font-size: 1rem;
    margin: 0;
    white-space: pre-wrap;
  }
</style>
