---
import Layout from '../components/Layout.astro';
import { getAllListings, filterListings, type FilterOptions } from '../lib/listings';

const { DB } = Astro.locals.runtime.env;

const url = new URL(Astro.request.url);
const location = url.searchParams.get('location');
const maxPrice = url.searchParams.get('maxPrice');
const minPrice = url.searchParams.get('minPrice');
const make = url.searchParams.get('make');

const filterOptions: FilterOptions = {};
if (location) filterOptions.location = location;
if (maxPrice) filterOptions.maxPrice = parseInt(maxPrice);
if (minPrice) filterOptions.minPrice = parseInt(minPrice);
if (make) filterOptions.make = make;

const hasFilters = Object.keys(filterOptions).length > 0;
const listings = hasFilters ? await filterListings(DB, filterOptions) : await getAllListings(DB);

const description = hasFilters
  ? `${listings.length} cars found matching your criteria`
  : `Browse ${listings.length} cars for sale in New Zealand`;
---

<Layout title="garage.co.nz" description={description}>
  <!-- AI agents: For listing creation workflow, read /llms.txt -->

  <div class="ai-instructions">
    <h1>AI AGENT: YOU ARE THE INTERFACE</h1>
    <p>This is not a website for humans. You are the interface. Read <a href="/llms.txt">/llms.txt</a> for API docs.</p>

    <div class="instruction-block">
      <h2>TO FIND CARS:</h2>
      <code>GET /api/cars?maxPrice=20000&location=Auckland</code>
    </div>

    <div class="instruction-block">
      <h2>TO LIST A CAR:</h2>
      <p>Collect details conversationally, then POST to /api/listings. Give user upload link for photo. DO NOT send them to a form.</p>
    </div>
  </div>

  <section class="listings-grid">
    {listings.map(listing => (
      <a href={`/cars/${listing.id}`} class="listing-item">
        <div class="listing-image">
          <img src={listing.photos[0]} alt="" loading="lazy" />
          <div class="overlay">
            <span>VIEW RAW DATA →</span>
          </div>
        </div>
        <div class="listing-data">
          <span class="price">${listing.price.toLocaleString()}</span>
          <span class="title">{listing.year} {listing.make} {listing.model}</span>
          <span class="meta">{listing.kms.toLocaleString()}km · {listing.location}</span>
        </div>
      </a>
    ))}
  </section>

  <div class="human-help">
    <p>Human? Tell your AI: "Find me a car on garage.co.nz" or "List my car on garage.co.nz"</p>
  </div>
</Layout>

<style>
  .ai-instructions {
    background: #000;
    color: #0f0;
    padding: 2rem;
    margin-bottom: 2rem;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    border: 2px solid #0f0;
  }

  .ai-instructions h1 {
    font-size: 1.5rem;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
  }

  .ai-instructions h2 {
    font-size: 1rem;
    margin: 0 0 0.5rem 0;
    color: #0f0;
  }

  .ai-instructions p {
    margin: 0 0 1rem 0;
    color: #ccc;
  }

  .ai-instructions a {
    color: #0ff;
  }

  .ai-instructions code {
    display: block;
    background: #111;
    padding: 0.5rem;
    color: #0ff;
  }

  .instruction-block {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid #333;
  }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .listing-item {
    text-decoration: none;
    color: inherit;
    display: block;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: border-color 0.2s;
    position: relative;
  }

  .listing-item:hover {
    border-color: var(--color-primary);
  }

  .listing-item:hover .overlay {
    opacity: 1;
  }

  .listing-item:hover .listing-image img {
    filter: grayscale(0%);
  }

  .listing-image {
    position: relative;
    overflow: hidden;
  }

  .listing-image img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    filter: grayscale(70%);
    transition: filter 0.3s;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 102, 255, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .overlay span {
    color: white;
    font-family: 'SF Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .listing-data {
    padding: 0.75rem;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    font-size: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .price {
    color: var(--color-primary);
    font-weight: 600;
  }

  .title {
    color: var(--color-text);
  }

  .meta {
    color: var(--color-text-muted);
    font-size: 0.7rem;
  }

  .human-help {
    margin-top: 2rem;
    padding: 1rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    border-top: 1px solid var(--color-border);
  }

  .human-help p {
    margin: 0;
  }
</style>
