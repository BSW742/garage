---
import Layout from '../components/Layout.astro';
---

<Layout title="Home">
  <section class="hero">
    <h1>Is your website ready for AI search?</h1>
    <p class="subtitle">
      ChatGPT, Claude, and Perplexity are becoming the new search engines.
      Find out if they can understand your business.
    </p>

    <form id="audit-form" class="audit-form">
      <div class="input-group">
        <input
          type="text"
          id="url-input"
          name="url"
          placeholder="example.com"
          required
          autocomplete="url"
        />
        <button type="submit" id="submit-btn">
          <span class="btn-text">Check</span>
          <span class="btn-loading" style="display: none;">
            <svg class="spinner" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4 31.4" />
            </svg>
          </span>
        </button>
      </div>
      <p class="hint">Free instant audit · No signup required</p>
    </form>
  </section>

  <!-- Results section (hidden initially) -->
  <section id="results" class="results" style="display: none;">
    <div class="score-display">
      <div id="score-circle" class="score-circle">
        <span id="score-number">0</span>
        <span class="score-label">/100</span>
      </div>
      <h2 id="score-title">Checking...</h2>
      <p id="score-summary" class="score-summary"></p>
    </div>

    <div class="checks-preview" id="checks-preview">
      <!-- Filled by JS -->
    </div>

    <div class="cta-section" id="cta-section">
      <h3>Get your detailed report</h3>
      <p>See exactly what to fix and how to do it.</p>

      <form id="lead-form" class="lead-form">
        <input type="hidden" id="audit-id" name="audit_id" />
        <div class="form-row">
          <input type="text" name="name" placeholder="Your name" required />
          <input type="email" name="email" placeholder="Your email" required />
        </div>
        <button type="submit" id="lead-submit-btn">
          <span class="btn-text">Get My Report</span>
          <span class="btn-loading" style="display: none;">
            <svg class="spinner" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4 31.4" />
            </svg>
          </span>
        </button>
      </form>
    </div>
  </section>

  <!-- Detailed report (shown after email submission) -->
  <section id="detailed-report" class="detailed-report" style="display: none;">
    <h2>Your AI Readiness Report</h2>
    <div id="report-content">
      <!-- Filled by JS -->
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem 3rem;
  }

  .hero h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    color: var(--color-text);
    line-height: 1.2;
  }

  .hero .subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0 0 2.5rem 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .audit-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .input-group {
    display: flex;
    gap: 0.5rem;
    background: var(--color-surface);
    padding: 0.5rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .input-group input {
    flex: 1;
    border: none;
    padding: 1rem;
    font-size: 1rem;
    background: transparent;
    outline: none;
  }

  .input-group button {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 100px;
  }

  .input-group button:hover {
    background: var(--color-primary-dark);
  }

  .input-group button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .hint {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
  }

  .spinner {
    width: 20px;
    height: 20px;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Results */
  .results {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .score-display {
    text-align: center;
    margin-bottom: 2rem;
  }

  .score-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    transition: background 0.3s;
  }

  .score-circle.red { background: linear-gradient(135deg, #fecaca, #fca5a5); }
  .score-circle.amber { background: linear-gradient(135deg, #fef08a, #fde047); }
  .score-circle.green { background: linear-gradient(135deg, #bbf7d0, #86efac); }

  #score-number {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .score-label {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  #score-title {
    font-size: 1.5rem;
    margin: 0 0 0.5rem 0;
  }

  .score-summary {
    color: var(--color-text-muted);
    max-width: 400px;
    margin: 0 auto;
  }

  .checks-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.75rem;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 12px;
  }

  .check-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .check-item.pass { color: var(--color-green); }
  .check-item.fail { color: var(--color-red); }

  .cta-section {
    text-align: center;
    padding: 2rem;
    background: var(--color-surface);
    border-radius: 12px;
    margin-top: 2rem;
  }

  .cta-section h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
  }

  .cta-section > p {
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
  }

  .lead-form {
    max-width: 400px;
    margin: 0 auto;
  }

  .form-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .form-row input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
  }

  .lead-form button {
    width: 100%;
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 1rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lead-form button:hover {
    background: var(--color-primary-dark);
  }

  /* Detailed report */
  .detailed-report {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .detailed-report h2 {
    margin-bottom: 1.5rem;
  }

  .report-section {
    background: var(--color-surface);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .report-section h4 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem 0;
  }

  .report-section.pass h4 { color: var(--color-green); }
  .report-section.fail h4 { color: var(--color-red); }

  .report-section p {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  .report-section code {
    background: var(--color-bg);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 1.75rem;
    }

    .input-group {
      flex-direction: column;
    }

    .input-group button {
      width: 100%;
    }

    .form-row {
      flex-direction: column;
    }
  }
</style>

<script>
  // A/B test variant
  const variant = localStorage.getItem('ab_variant') || (Math.random() < 0.5 ? 'A' : 'B');
  localStorage.setItem('ab_variant', variant);

  // Update CTA button text based on variant
  const leadSubmitBtn = document.getElementById('lead-submit-btn');
  if (leadSubmitBtn && variant === 'B') {
    const btnText = leadSubmitBtn.querySelector('.btn-text');
    if (btnText) btnText.textContent = 'Email Me the Report';
  }

  // Store audit data for later
  let auditData: any = null;

  // Audit form submission
  const auditForm = document.getElementById('audit-form') as HTMLFormElement;
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  auditForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    let url = urlInput.value.trim();
    if (!url) return;

    // Auto-add https:// if missing
    if (!url.startsWith('http://') && !url.startsWith('https://')) {
      url = 'https://' + url;
    }

    // Show loading state
    submitBtn.disabled = true;
    submitBtn.querySelector('.btn-text')!.style.display = 'none';
    submitBtn.querySelector('.btn-loading')!.style.display = 'block';

    try {
      const response = await fetch('/api/audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url, variant })
      });

      if (!response.ok) {
        throw new Error('Audit failed');
      }

      auditData = await response.json();
      displayResults(auditData);

    } catch (error) {
      alert('Failed to audit website. Please check the URL and try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.querySelector('.btn-text')!.style.display = 'block';
      submitBtn.querySelector('.btn-loading')!.style.display = 'none';
    }
  });

  function displayResults(data: any) {
    const resultsSection = document.getElementById('results')!;
    const scoreCircle = document.getElementById('score-circle')!;
    const scoreNumber = document.getElementById('score-number')!;
    const scoreTitle = document.getElementById('score-title')!;
    const scoreSummary = document.getElementById('score-summary')!;
    const checksPreview = document.getElementById('checks-preview')!;
    const auditIdInput = document.getElementById('audit-id') as HTMLInputElement;

    // Set score
    scoreNumber.textContent = data.score.toString();
    auditIdInput.value = data.id;

    // Set color class
    scoreCircle.className = 'score-circle';
    if (data.score >= 70) {
      scoreCircle.classList.add('green');
      scoreTitle.textContent = 'AI Ready';
      scoreSummary.textContent = 'Your website is well-optimized for AI search engines.';
    } else if (data.score >= 40) {
      scoreCircle.classList.add('amber');
      scoreTitle.textContent = 'Partially Ready';
      scoreSummary.textContent = 'Your site has good basics but is missing some AI discovery features.';
    } else {
      scoreCircle.classList.add('red');
      scoreTitle.textContent = 'Not AI Ready';
      scoreSummary.textContent = 'AI assistants will struggle to understand your business.';
    }

    // Show checks preview
    const checks = [
      { key: 'meta', label: 'Meta description' },
      { key: 'robots', label: 'robots.txt' },
      { key: 'llms_txt', label: 'llms.txt' },
      { key: 'llm_ld', label: 'LLM-LD' },
      { key: 'schema', label: 'Schema.org' },
      { key: 'https', label: 'HTTPS' },
    ];

    checksPreview.innerHTML = checks.map(check => {
      const score = data.checks[check.key]?.score || 0;
      const pass = score > 50;
      return `
        <div class="check-item ${pass ? 'pass' : 'fail'}">
          ${pass ? '✓' : '✗'} ${check.label}
        </div>
      `;
    }).join('');

    // Show results section
    resultsSection.style.display = 'block';
    resultsSection.scrollIntoView({ behavior: 'smooth' });
  }

  // Lead form submission
  const leadForm = document.getElementById('lead-form') as HTMLFormElement;
  const leadSubmitButton = document.getElementById('lead-submit-btn') as HTMLButtonElement;

  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(leadForm);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const auditId = formData.get('audit_id') as string;

    // Show loading
    leadSubmitButton.disabled = true;
    leadSubmitButton.querySelector('.btn-text')!.style.display = 'none';
    leadSubmitButton.querySelector('.btn-loading')!.style.display = 'block';

    try {
      const response = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ audit_id: auditId, name, email })
      });

      if (!response.ok) {
        throw new Error('Failed to save');
      }

      // Hide CTA, show detailed report
      document.getElementById('cta-section')!.style.display = 'none';
      displayDetailedReport(auditData);

    } catch (error) {
      alert('Something went wrong. Please try again.');
    } finally {
      leadSubmitButton.disabled = false;
      leadSubmitButton.querySelector('.btn-text')!.style.display = 'block';
      leadSubmitButton.querySelector('.btn-loading')!.style.display = 'none';
    }
  });

  function displayDetailedReport(data: any) {
    const reportSection = document.getElementById('detailed-report')!;
    const reportContent = document.getElementById('report-content')!;

    const checkDetails = [
      {
        key: 'meta',
        label: 'Meta Description',
        passText: 'Your meta description is well-crafted and helps AI understand your page.',
        failText: 'Add a clear meta description (50-160 characters) that explains what your business does.'
      },
      {
        key: 'robots',
        label: 'robots.txt',
        passText: 'Your robots.txt is properly configured.',
        failText: 'Create a robots.txt file at your site root. Ensure AI bots are not blocked.'
      },
      {
        key: 'llms_txt',
        label: 'llms.txt',
        passText: 'Great! You have an llms.txt file for AI discovery.',
        failText: 'Add /llms.txt with instructions for AI assistants. Over 844K sites use this standard.'
      },
      {
        key: 'llm_ld',
        label: 'LLM-LD (AI Structured Data)',
        passText: 'Excellent! You have LLM-LD structured data.',
        failText: 'Add /.well-known/llm-index.json with machine-readable AI instructions.'
      },
      {
        key: 'schema',
        label: 'Schema.org Markup',
        passText: 'Schema.org structured data found on your page.',
        failText: 'Add JSON-LD Schema.org markup to help AI understand your content structure.'
      },
      {
        key: 'https',
        label: 'HTTPS Security',
        passText: 'Your site uses HTTPS.',
        failText: 'Switch to HTTPS. AI assistants may warn users about insecure sites.'
      },
    ];

    reportContent.innerHTML = checkDetails.map(check => {
      const checkData = data.checks[check.key];
      const pass = checkData?.score > 50;
      return `
        <div class="report-section ${pass ? 'pass' : 'fail'}">
          <h4>${pass ? '✓' : '✗'} ${check.label}</h4>
          <p>${pass ? check.passText : check.failText}</p>
        </div>
      `;
    }).join('');

    reportSection.style.display = 'block';
    reportSection.scrollIntoView({ behavior: 'smooth' });
  }
</script>
