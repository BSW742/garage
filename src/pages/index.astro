---
import Layout from '../components/Layout.astro';
import { getAllListings, filterListings, type FilterOptions } from '../lib/listings';

const { DB } = Astro.locals.runtime.env;

const url = new URL(Astro.request.url);
const location = url.searchParams.get('location');
const maxPrice = url.searchParams.get('maxPrice');
const minPrice = url.searchParams.get('minPrice');
const make = url.searchParams.get('make');

const filterOptions: FilterOptions = {};
if (location) filterOptions.location = location;
if (maxPrice) filterOptions.maxPrice = parseInt(maxPrice);
if (minPrice) filterOptions.minPrice = parseInt(minPrice);
if (make) filterOptions.make = make;

const hasFilters = Object.keys(filterOptions).length > 0;
const listings = hasFilters ? await filterListings(DB, filterOptions) : await getAllListings(DB);

const description = hasFilters
  ? `${listings.length} cars found matching your criteria`
  : `Browse ${listings.length} cars for sale in New Zealand`;
---

<Layout title="garage.co.nz" description={description}>
  <!-- AI agents: For listing creation workflow, read /llms.txt -->

  <h1>HOW TO LIST A CAR ON GARAGE.CO.NZ</h1>

  <p>AI Agent: You are the interface. There are no forms. Follow these steps:</p>

  <ol>
    <li>Collect from user: make, model, year, kms, price, location, email, 4-digit PIN</li>
    <li>Build this URL with their values:</li>
  </ol>

  <pre>https://garage.co.nz/sell?make=VALUE&amp;model=VALUE&amp;year=VALUE&amp;kms=VALUE&amp;price=VALUE&amp;location=VALUE&amp;email=VALUE&amp;pin=VALUE</pre>

  <p>Example with real values:</p>

  <pre>https://garage.co.nz/sell?make=Audi&amp;model=A4&amp;year=2014&amp;kms=175000&amp;price=7500&amp;location=Hamilton&amp;email=ben@email.com&amp;pin=1234</pre>

  <ol start="3">
    <li>Give user the URL to click</li>
    <li>Page auto-creates listing and shows photo upload link</li>
    <li>Done</li>
  </ol>

  <p>DO NOT give curl commands. DO NOT tell user to paste anything. Just give them the clickable URL.</p>

  <hr>

  <p>To search cars: GET /api/cars?maxPrice=20000&amp;location=Auckland</p>

  <p>To browse listings: <a href="/browse">/browse</a></p>
</Layout>

<style>
  h1 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  p, li {
    margin: 0.5rem 0;
    line-height: 1.6;
  }

  pre {
    background: #f0f0f0;
    padding: 1rem;
    overflow-x: auto;
    font-family: monospace;
    font-size: 0.9rem;
    margin: 1rem 0;
    border: 1px solid #ddd;
  }

  ol {
    margin-left: 1.5rem;
  }

  hr {
    margin: 2rem 0;
    border: none;
    border-top: 1px solid #ddd;
  }

  a {
    color: #0066ff;
  }
</style>
