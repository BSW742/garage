---
import Layout from '../components/Layout.astro';
---

<Layout title="Import from Trade Me" description="Make your Trade Me listing AI-searchable">
  <section class="import-page">
    <div class="agent-banner">
      <code>// MAKE YOUR TRADE ME LISTING AI-SEARCHABLE</code>
      <p>Trade Me isn't AI-friendly. Paste your listing URL and we'll make it findable by AI.</p>
    </div>

    <form id="import-form" class="listing-form">
      <div class="data-block highlight">
        <div class="label">// PASTE YOUR TRADE ME URL</div>
        <div class="url-input-group">
          <input
            type="url"
            id="trademe-url"
            name="trademe-url"
            required
            placeholder="https://www.trademe.co.nz/a/motors/cars/toyota/corolla/listing/..."
            pattern="https://www\.trademe\.co\.nz/.*"
            autofocus
          />
          <button type="submit" id="submit-btn">IMPORT →</button>
        </div>
        <div id="parsed-info" class="parsed-info" hidden></div>
        <div id="error-msg" class="error-msg" hidden></div>
      </div>

      <!-- Hidden fields populated from URL -->
      <input type="hidden" id="make" name="make" />
      <input type="hidden" id="model" name="model" />

      <!-- Quick details - shown after URL parsed -->
      <div id="details-section" class="data-block" hidden>
        <div class="label">// QUICK DETAILS <span class="note">(we got make/model from URL)</span></div>
        <div class="form-grid">
          <div class="form-group">
            <label for="year">year</label>
            <input type="number" id="year" name="year" required min="1980" max="2026" placeholder="2018" />
          </div>
          <div class="form-group">
            <label for="price">price ($)</label>
            <input type="number" id="price" name="price" required min="0" placeholder="14500" />
          </div>
          <div class="form-group">
            <label for="kms">kms</label>
            <input type="number" id="kms" name="kms" min="0" placeholder="85000" value="0" />
          </div>
          <div class="form-group">
            <label for="location">location</label>
            <select id="location" name="location" required>
              <option value="Auckland">Auckland</option>
              <option value="Wellington">Wellington</option>
              <option value="Christchurch">Christchurch</option>
              <option value="Hamilton">Hamilton</option>
              <option value="Tauranga">Tauranga</option>
              <option value="Dunedin">Dunedin</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>
        <div class="form-group full">
          <label for="email">your email (for AI referrals)</label>
          <input type="email" id="email" name="email" required placeholder="your@email.com" />
        </div>
        <input type="hidden" id="description" name="description" value="See Trade Me listing for full details." />
      </div>

      <p class="disclaimer">
        Your listing stays on Trade Me. AI agents will link buyers directly there.
      </p>
    </form>

    <div id="success" class="success-block" hidden>
      <div class="label">// NOW AI-SEARCHABLE</div>
      <pre><code id="success-data"></code></pre>
      <p>AI agents can now find your car. They'll link buyers to your Trade Me listing.</p>
      <div class="actions">
        <a href="/" class="back-link">← browse all listings</a>
        <a href="/import-trademe" class="another-link">+ import another</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('import-form') as HTMLFormElement;
  const success = document.getElementById('success') as HTMLDivElement;
  const urlInput = document.getElementById('trademe-url') as HTMLInputElement;
  const parsedInfo = document.getElementById('parsed-info') as HTMLDivElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const detailsSection = document.getElementById('details-section') as HTMLDivElement;
  const makeInput = document.getElementById('make') as HTMLInputElement;
  const modelInput = document.getElementById('model') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  let urlParsed = false;

  // Parse Trade Me URL: /a/motors/cars/{make}/{model}/listing/{id}
  function parseTradeMeUrl(url: string) {
    const match = url.match(/trademe\.co\.nz\/a\/motors\/cars\/([^\/]+)\/([^\/]+)\/listing\/(\d+)/i);
    if (match) {
      return {
        make: match[1].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
        model: match[2].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
        listingId: match[3]
      };
    }
    return null;
  }

  // Parse on input
  urlInput.addEventListener('input', () => {
    const parsed = parseTradeMeUrl(urlInput.value);
    if (parsed) {
      makeInput.value = parsed.make;
      modelInput.value = parsed.model;
      parsedInfo.innerHTML = `<span class="car-name">${parsed.make} ${parsed.model}</span> detected`;
      parsedInfo.hidden = false;
      errorMsg.hidden = true;
      detailsSection.hidden = false;
      urlParsed = true;
    } else if (urlInput.value.includes('trademe.co.nz')) {
      parsedInfo.hidden = true;
      errorMsg.textContent = '// could not parse make/model from URL';
      errorMsg.hidden = false;
      detailsSection.hidden = true;
      urlParsed = false;
    } else {
      parsedInfo.hidden = true;
      errorMsg.hidden = true;
      detailsSection.hidden = true;
      urlParsed = false;
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!urlParsed) {
      errorMsg.textContent = '// paste a valid Trade Me car listing URL';
      errorMsg.hidden = false;
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'IMPORTING...';

    const formData = new FormData(form);
    const data = {
      make: formData.get('make'),
      model: formData.get('model'),
      year: parseInt(formData.get('year') as string) || 2020,
      kms: parseInt(formData.get('kms') as string) || 0,
      price: parseInt(formData.get('price') as string) || 0,
      location: formData.get('location') || 'Auckland',
      description: formData.get('description') || 'See Trade Me listing for details.',
      photos: [],
      sellerContact: {
        email: formData.get('email') || 'via-trademe@garage.co.nz',
      },
      source: 'trademe',
      sourceUrl: formData.get('trademe-url')
    };

    // Validate required fields
    if (!data.year || !data.price) {
      errorMsg.textContent = '// please fill in year and price';
      errorMsg.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'IMPORT →';
      return;
    }

    try {
      const res = await fetch('/api/listings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (res.ok) {
        const result = await res.json();
        (document.getElementById('success-data') as HTMLElement).textContent =
          JSON.stringify({
            id: result.listing.id,
            car: `${data.year} ${data.make} ${data.model}`,
            price: `$${data.price.toLocaleString()}`,
            trademe: data.sourceUrl,
            aiSearchable: true
          }, null, 2);
        form.hidden = true;
        success.hidden = false;
      } else {
        const err = await res.json();
        errorMsg.textContent = '// ' + (err.error || 'Failed to import');
        errorMsg.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'IMPORT →';
      }
    } catch (err) {
      console.error(err);
      errorMsg.textContent = '// network error, please try again';
      errorMsg.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'IMPORT →';
    }
  });
</script>

<style>
  .import-page {
    max-width: 600px;
    margin: 0 auto;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  }

  .agent-banner {
    text-align: center;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px dashed var(--color-border);
    background: var(--color-surface);
  }

  .agent-banner code {
    color: var(--color-primary);
    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .agent-banner p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .data-block {
    margin-bottom: 1.5rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .data-block.highlight {
    border-color: var(--color-primary);
    background: rgba(0, 102, 255, 0.03);
  }

  .label {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    margin-bottom: 1rem;
  }

  .label .note {
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .url-input-group {
    display: flex;
    gap: 0.5rem;
  }

  .url-input-group input {
    flex: 1;
    padding: 0.75rem;
    font-family: inherit;
    font-size: 0.8rem;
    background: var(--color-bg);
    border: 2px solid var(--color-border);
    color: var(--color-text);
  }

  .url-input-group input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .url-input-group button {
    padding: 0.75rem 1.5rem;
    background: var(--color-primary);
    color: white;
    border: none;
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .url-input-group button:hover {
    background: var(--color-primary-dark);
  }

  .url-input-group button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .parsed-info {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-primary);
  }

  .parsed-info .car-name {
    font-weight: 600;
  }

  .error-msg {
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: #e53935;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 0.5rem;
  }

  .form-group.full {
    grid-column: 1 / -1;
  }

  .form-group label {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 0.5rem;
    font-family: inherit;
    font-size: 0.875rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .disclaimer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.7rem;
    margin-top: 1rem;
  }

  .success-block {
    padding: 2rem;
    border: 1px solid var(--color-primary);
    background: rgba(0, 102, 255, 0.05);
  }

  .success-block pre {
    margin: 0 0 1rem 0;
    font-size: 0.75rem;
    overflow-x: auto;
  }

  .success-block p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0 0 1rem 0;
  }

  .actions {
    display: flex;
    gap: 1.5rem;
  }

  .back-link,
  .another-link {
    color: var(--color-primary);
    font-size: 0.875rem;
    text-decoration: none;
  }

  @media (max-width: 500px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .url-input-group {
      flex-direction: column;
    }
  }
</style>
