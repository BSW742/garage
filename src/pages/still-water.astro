          lfo.type = 'sine';
          lfo.frequency.value = 0.2;

          const lfoGain = this.ctx.createGain();
          lfoGain.gain.value = 5;

          lfo.connect(lfoGain);
          lfoGain.connect(this.droneNode.frequency);

          this.droneGain = this.ctx.createGain();
          this.droneGain.gain.setValueAtTime(0, this.ctx.currentTime);
          this.droneGain.gain.linearRampToValueAtTime(0.08, this.ctx.currentTime + 2);

          this.droneNode.connect(this.droneGain);
          this.droneGain.connect(this.masterGain);

          this.droneNode.start();
          lfo.start();
        },

        stopDrone() {
          if (this.droneNode && this.droneGain) {
            this.droneGain.gain.linearRampToValueAtTime(0, this.ctx.currentTime + 1);
            setTimeout(() => {
              if (this.droneNode) {
