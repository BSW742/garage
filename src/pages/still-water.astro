---
// STILL WATER - Chapter 1: The Flood Comes
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>STILL WATER | Chapter 1</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Special+Elite&family=Inter:wght@300;400;600&display=swap');

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: #0a0a0c;
        color: #e8e8e8;
        font-family: 'Inter', sans-serif;
        overflow: hidden;
        min-height: 100vh;
      }

      #game {
        width: 100vw;
        height: 100vh;
        position: relative;
        overflow: hidden;
      }

      /* Rain canvas */
      #rain-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 10;
        opacity: 0.6;
      }

      /* Scene container */
      #scene {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      #scene-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        filter: brightness(0.4) saturate(0.7);
        transition: opacity 1s ease;
      }

      /* Character portrait */
      #portrait {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        height: 70%;
        opacity: 0;
        transition: opacity 0.5s ease, transform 0.5s ease;
        filter: drop-shadow(0 0 30px rgba(0,0,0,0.8));
        z-index: 5;
      }

      #portrait.visible {
        opacity: 1;
      }

      /* Vignette */
      #vignette {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(ellipse at center, transparent 0%, transparent 40%, rgba(0,0,0,0.8) 100%);
        pointer-events: none;
        z-index: 15;
      }

      /* Chapter title */
      #chapter-title {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        z-index: 100;
        opacity: 0;
        transition: opacity 1s ease;
      }

      #chapter-title.visible { opacity: 1; }

      #chapter-title .chapter-num {
        font-family: 'Special Elite', monospace;
        font-size: 14px;
        letter-spacing: 8px;
        color: #666;
        text-transform: uppercase;
        margin-bottom: 20px;
      }

      #chapter-title .chapter-name {
        font-family: 'Special Elite', monospace;
        font-size: 48px;
        color: #fff;
        text-shadow: 0 0 40px rgba(100, 150, 200, 0.5);
        letter-spacing: 4px;
      }

      #chapter-title .chapter-location {
        font-size: 14px;
        color: #888;
        margin-top: 30px;
        font-weight: 300;
      }

      /* Character intro card */
      #char-intro {
        position: absolute;
        left: 60px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 100;
        opacity: 0;
        transition: opacity 0.8s ease, transform 0.8s ease;
      }

      #char-intro.visible {
        opacity: 1;
      }

      #char-intro .char-name {
        font-family: 'Special Elite', monospace;
        font-size: 36px;
        color: #fff;
        letter-spacing: 3px;
        margin-bottom: 8px;
      }

      #char-intro .char-role {
        font-size: 13px;
        color: #4a9eff;
        text-transform: uppercase;
        letter-spacing: 4px;
        margin-bottom: 20px;
      }

      #char-intro .char-desc {
        font-size: 14px;
        color: #999;
        max-width: 300px;
        line-height: 1.7;
        font-weight: 300;
      }

      /* Dialogue box */
      #dialogue-container {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 40px 60px;
        background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.8) 70%, transparent 100%);
        z-index: 50;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.4s ease, transform 0.4s ease;
      }

      #dialogue-container.visible {
        opacity: 1;
        transform: translateY(0);
      }

      #speaker {
        font-family: 'Special Elite', monospace;
        font-size: 14px;
        color: #4a9eff;
        letter-spacing: 2px;
        margin-bottom: 12px;
        text-transform: uppercase;
      }

      #dialogue {
        font-size: 20px;
        line-height: 1.6;
        color: #e8e8e8;
        max-width: 900px;
        min-height: 60px;
      }

      #dialogue .highlight {
        color: #4a9eff;
      }

      #continue-prompt {
        position: absolute;
        bottom: 15px;
        right: 60px;
        font-size: 12px;
        color: #666;
        opacity: 0;
        animation: pulse 2s infinite;
      }

      #continue-prompt.visible { opacity: 1; }

      @keyframes pulse {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
      }

      /* Choices */
      #choices {
        position: absolute;
        bottom: 150px;
        left: 60px;
        z-index: 60;
        display: none;
      }

      #choices.visible { display: block; }

      .choice {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-left: 3px solid #4a9eff;
        padding: 15px 25px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
        max-width: 500px;
        position: relative;
      }

      .choice:hover {
        background: rgba(74, 158, 255, 0.1);
        border-left-color: #fff;
        transform: translateX(5px);
      }

      .choice-key {
        position: absolute;
        left: -40px;
        top: 50%;
        transform: translateY(-50%);
        width: 28px;
        height: 28px;
        border: 1px solid #4a9eff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        color: #4a9eff;
        font-family: 'Special Elite', monospace;
      }

      .choice-text {
        font-size: 15px;
        color: #ccc;
      }

      .choice-timer {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 2px;
        background: #4a9eff;
        transition: width 0.1s linear;
      }

      /* QTE */
      #qte-container {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 100;
        display: none;
        text-align: center;
      }

      #qte-container.visible { display: block; }

      .qte-prompt {
        font-family: 'Special Elite', monospace;
        font-size: 14px;
        color: #888;
        margin-bottom: 20px;
        letter-spacing: 2px;
      }

      .qte-key {
        width: 100px;
        height: 100px;
        border: 3px solid #4a9eff;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Special Elite', monospace;
        font-size: 42px;
        color: #4a9eff;
        margin: 0 auto 20px;
        position: relative;
        background: rgba(0,0,0,0.8);
        transition: all 0.15s ease;
      }

      .qte-key.pressing {
        background: rgba(74, 158, 255, 0.3);
        transform: scale(0.95);
        border-color: #fff;
        color: #fff;
      }

      .qte-key.success {
        border-color: #4ade80;
        color: #4ade80;
        animation: qteSuccess 0.5s ease;
      }

      .qte-key.fail {
        border-color: #ef4444;
        color: #ef4444;
        animation: qteFail 0.5s ease;
      }

      @keyframes qteSuccess {
        0% { transform: scale(1); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1); }
      }

      @keyframes qteFail {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-10px); }
        40%, 80% { transform: translateX(10px); }
      }

      .qte-timer {
        width: 200px;
        height: 6px;
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
        margin: 0 auto;
        overflow: hidden;
      }

      .qte-timer-fill {
        height: 100%;
        background: #4a9eff;
        transition: width 0.05s linear;
      }

      .qte-timer-fill.warning { background: #f59e0b; }
      .qte-timer-fill.danger { background: #ef4444; }

      /* Hold QTE */
      .qte-hold-ring {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 4px solid rgba(255,255,255,0.2);
        position: relative;
        margin: 0 auto 20px;
      }

      .qte-hold-progress {
        position: absolute;
        top: -4px;
        left: -4px;
        width: 120px;
        height: 120px;
      }

      .qte-hold-key {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-family: 'Special Elite', monospace;
        font-size: 36px;
        color: #4a9eff;
      }

      /* Sequence QTE */
      .qte-sequence {
        display: flex;
        gap: 15px;
        justify-content: center;
        margin-bottom: 20px;
      }

      .qte-seq-key {
        width: 60px;
        height: 60px;
        border: 2px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Special Elite', monospace;
        font-size: 24px;
        color: #666;
        background: rgba(0,0,0,0.6);
        transition: all 0.2s ease;
      }

      .qte-seq-key.active {
        border-color: #4a9eff;
        color: #4a9eff;
        transform: scale(1.1);
      }

      .qte-seq-key.done {
        border-color: #4ade80;
        color: #4ade80;
      }

      .qte-seq-key.missed {
        border-color: #ef4444;
        color: #ef4444;
      }

      /* Narrative text (for internal monologue) */
      #narrative {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        max-width: 700px;
        z-index: 80;
        opacity: 0;
        transition: opacity 0.8s ease;
      }

      #narrative.visible { opacity: 1; }

      #narrative p {
        font-size: 22px;
        color: #bbb;
        line-height: 1.8;
        font-style: italic;
        font-weight: 300;
      }

      /* Scene transition */
      #transition {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #000;
        z-index: 200;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.8s ease;
      }

      #transition.active {
        opacity: 1;
        pointer-events: all;
      }

      /* Time/location stamp */
      #timestamp {
        position: absolute;
        top: 40px;
        left: 60px;
        z-index: 80;
        opacity: 0;
        transition: opacity 0.5s ease;
      }

      #timestamp.visible { opacity: 1; }

      #timestamp .time {
        font-family: 'Special Elite', monospace;
        font-size: 28px;
        color: #fff;
        letter-spacing: 2px;
      }

      #timestamp .location {
        font-size: 12px;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-top: 5px;
      }

      /* Heartbeat effect for tension */
      .heartbeat {
        animation: heartbeat 1s infinite;
      }

      @keyframes heartbeat {
        0%, 100% { transform: translate(-50%, -50%) scale(1); }
        15% { transform: translate(-50%, -50%) scale(1.03); }
        30% { transform: translate(-50%, -50%) scale(1); }
        45% { transform: translate(-50%, -50%) scale(1.02); }
      }

      /* Game state indicator */
      #state-indicator {
        position: absolute;
        top: 40px;
        right: 60px;
        z-index: 80;
        text-align: right;
      }

      #current-char {
        font-family: 'Special Elite', monospace;
        font-size: 12px;
        color: #4a9eff;
        letter-spacing: 2px;
      }

      /* Thought prompt */
      #thought {
        position: absolute;
        top: 120px;
        left: 50%;
        transform: translateX(-50%);
        font-style: italic;
        color: #888;
        font-size: 16px;
        text-align: center;
        max-width: 600px;
        opacity: 0;
        transition: opacity 0.5s ease;
        z-index: 80;
      }

      #thought.visible { opacity: 1; }

      /* Sound indicator (visual since we may not have audio) */
      #sound-indicator {
        position: absolute;
        bottom: 200px;
        right: 60px;
        font-size: 12px;
        color: #444;
        font-style: italic;
        z-index: 80;
      }

      /* Screen shake */
      .shake {
        animation: shake 0.5s ease;
      }

      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
      }

      /* Flash */
      #flash {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #fff;
        z-index: 180;
        opacity: 0;
        pointer-events: none;
      }

      #flash.active {
        animation: flash 0.3s ease;
      }

      @keyframes flash {
        0% { opacity: 0.8; }
        100% { opacity: 0; }
      }

      /* Lightning bolt */
      #lightning {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 175;
        opacity: 0;
      }

      #lightning.strike {
        animation: lightning-flash 0.6s ease;
      }

      @keyframes lightning-flash {
        0% { opacity: 0; }
        10% { opacity: 1; }
        20% { opacity: 0.3; }
        30% { opacity: 1; }
        40% { opacity: 0.5; }
        50% { opacity: 0.8; }
        100% { opacity: 0; }
      }

      .lightning-bolt {
        position: absolute;
        filter: drop-shadow(0 0 10px #fff) drop-shadow(0 0 30px #88c0ff) drop-shadow(0 0 60px #4a9eff);
      }

      /* QTE instruction text */
      .qte-instruction {
        font-size: 12px;
        color: #888;
        margin-top: 15px;
        letter-spacing: 1px;
      }

      .qte-instruction strong {
        color: #4a9eff;
      }

      /* Consequence display */
      #consequence {
        position: absolute;
        top: 40%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        z-index: 150;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
      }

      #consequence.visible {
        opacity: 1;
      }

      #consequence.success .consequence-text {
        color: #4ade80;
      }

      #consequence.fail .consequence-text {
        color: #ef4444;
      }

      .consequence-text {
        font-family: 'Special Elite', monospace;
        font-size: 18px;
        letter-spacing: 2px;
        text-shadow: 0 0 20px currentColor;
      }

      /* Lightning reveal - scene brightens */
      #scene-bg.lightning-reveal {
        animation: scene-flash 0.5s ease;
      }

      @keyframes scene-flash {
        0% { filter: brightness(0.4) saturate(0.7); }
        15% { filter: brightness(1.2) saturate(0.9); }
        30% { filter: brightness(0.6) saturate(0.7); }
        45% { filter: brightness(0.9) saturate(0.8); }
        100% { filter: brightness(0.4) saturate(0.7); }
      }

      /* Glimpse - shadowy figures that appear during lightning */
      #glimpse {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 8;
        opacity: 0;
      }

      #glimpse.visible {
        animation: glimpse-appear 0.5s ease;
      }

      @keyframes glimpse-appear {
        0% { opacity: 0; }
        15% { opacity: 0.9; }
        30% { opacity: 0.3; }
        45% { opacity: 0.6; }
        100% { opacity: 0; }
      }

      /* Silhouette figure */
      .silhouette {
        position: absolute;
        filter: blur(1px);
      }

      .silhouette-figure {
        fill: #0a0a0c;
        opacity: 0.95;
      }

      .silhouette-eyes {
        fill: none;
      }

      /* When glimpse is showing during lightning, eyes might glow */
      #glimpse.visible .silhouette-eyes {
        fill: rgba(255, 100, 100, 0.3);
        animation: eye-glint 0.15s ease;
      }

      @keyframes eye-glint {
        0% { fill: rgba(255, 100, 100, 0); }
        50% { fill: rgba(255, 100, 100, 0.4); }
        100% { fill: rgba(255, 100, 100, 0); }
      }
    </style>
  </head>
  <body>
    <div id="game">
      <canvas id="rain-canvas"></canvas>

      <div id="scene">
        <div id="scene-bg"></div>
        <div id="glimpse"></div>
      </div>

      <canvas id="portrait"></canvas>

      <div id="vignette"></div>
      <div id="transition"></div>
      <div id="flash"></div>
      <svg id="lightning" viewBox="0 0 100 100" preserveAspectRatio="none"></svg>
      <div id="consequence">
        <div class="consequence-text"></div>
      </div>

      <div id="chapter-title">
        <div class="chapter-num">Chapter One</div>
        <div class="chapter-name">THE FLOOD COMES</div>
        <div class="chapter-location">Millbrook, Oregon — October 15th</div>
      </div>

      <div id="char-intro">
        <div class="char-name"></div>
        <div class="char-role"></div>
        <div class="char-desc"></div>
      </div>

      <div id="timestamp">
        <div class="time"></div>
        <div class="location"></div>
      </div>

      <div id="state-indicator">
        <div id="current-char"></div>
      </div>

      <div id="thought"></div>

      <div id="narrative">
        <p></p>
      </div>

      <div id="dialogue-container">
        <div id="speaker"></div>
        <div id="dialogue"></div>
        <div id="continue-prompt">SPACE to continue</div>
      </div>

      <div id="choices"></div>

      <div id="qte-container"></div>

      <div id="sound-indicator"></div>
    </div>

    <script is:inline>
      // ============================================
      // STILL WATER - Game Engine
      // ============================================

      // ============================================
      // AUDIO ENGINE (Web Audio API)
      // ============================================

      const AudioEngine = {
        ctx: null,
        masterGain: null,
        initialized: false,

        // Active sound nodes
        rainNode: null,
        rainGain: null,
        thunderTimeout: null,
        heartbeatInterval: null,
        droneNode: null,
        droneGain: null,

        init() {
          if (this.initialized) return;

          this.ctx = new (window.AudioContext || window.webkitAudioContext)();
          this.masterGain = this.ctx.createGain();
          this.masterGain.gain.value = 0.5;
          this.masterGain.connect(this.ctx.destination);
          this.initialized = true;

          // Start ambient rain
          this.startRain();
          // Start random thunder
          this.scheduleThunder();
        },

        // Rain - filtered noise
        startRain() {
          if (!this.initialized) return;

          const bufferSize = 2 * this.ctx.sampleRate;
          const noiseBuffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
          const output = noiseBuffer.getChannelData(0);

          for (let i = 0; i < bufferSize; i++) {
            output[i] = Math.random() * 2 - 1;
          }

          this.rainNode = this.ctx.createBufferSource();
          this.rainNode.buffer = noiseBuffer;
          this.rainNode.loop = true;

          // Filter to make it sound like rain
          const lowpass = this.ctx.createBiquadFilter();
          lowpass.type = 'lowpass';
          lowpass.frequency.value = 400;

          const highpass = this.ctx.createBiquadFilter();
          highpass.type = 'highpass';
          highpass.frequency.value = 80;

          this.rainGain = this.ctx.createGain();
          this.rainGain.gain.value = 0.15;

          this.rainNode.connect(lowpass);
          lowpass.connect(highpass);
          highpass.connect(this.rainGain);
          this.rainGain.connect(this.masterGain);

          this.rainNode.start();
        },

        stopRain() {
          if (this.rainNode) {
            this.rainGain.gain.linearRampToValueAtTime(0, this.ctx.currentTime + 1);
            setTimeout(() => {
              this.rainNode.stop();
              this.rainNode = null;
            }, 1000);
          }
        },

        // Thunder rumble
        playThunder() {
          if (!this.initialized) return;

          const duration = 1.5 + Math.random();

          // Low rumble oscillator
          const osc = this.ctx.createOscillator();
          osc.type = 'sine';
          osc.frequency.value = 30 + Math.random() * 20;

          // Noise burst
          const noiseBuffer = this.ctx.createBuffer(1, this.ctx.sampleRate * duration, this.ctx.sampleRate);
          const output = noiseBuffer.getChannelData(0);
          for (let i = 0; i < output.length; i++) {
            output[i] = Math.random() * 2 - 1;
          }

          const noise = this.ctx.createBufferSource();
          noise.buffer = noiseBuffer;

          const noiseFilter = this.ctx.createBiquadFilter();
          noiseFilter.type = 'lowpass';
          noiseFilter.frequency.value = 150;

          // Envelope
          const gain = this.ctx.createGain();
          gain.gain.setValueAtTime(0, this.ctx.currentTime);
          gain.gain.linearRampToValueAtTime(0.4, this.ctx.currentTime + 0.1);
          gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + duration);

          osc.connect(gain);
          noise.connect(noiseFilter);
          noiseFilter.connect(gain);
          gain.connect(this.masterGain);

          osc.start();
          noise.start();
          osc.stop(this.ctx.currentTime + duration);
          noise.stop(this.ctx.currentTime + duration);

          // Visual flash and lightning
          document.getElementById('flash').classList.add('active');
          setTimeout(() => document.getElementById('flash').classList.remove('active'), 300);

          // Draw lightning bolt
          this.drawLightning();
        },

        drawLightning() {
          const svg = document.getElementById('lightning');
          const sceneBg = document.getElementById('scene-bg');
          const glimpse = document.getElementById('glimpse');
          const startX = 20 + Math.random() * 60;

          // Generate jagged lightning path
          let path = `M ${startX} 0 `;
          let x = startX;
          let y = 0;

          while (y < 100) {
            const dx = (Math.random() - 0.5) * 20;
            const dy = 5 + Math.random() * 10;
            x = Math.max(5, Math.min(95, x + dx));
            y += dy;
            path += `L ${x} ${y} `;

            // Occasional branch
            if (Math.random() < 0.3 && y < 80) {
              const branchX = x + (Math.random() - 0.5) * 30;
              const branchY = y + 10 + Math.random() * 15;
              svg.innerHTML += `<path class="lightning-bolt" d="M ${x} ${y} L ${branchX} ${branchY}" stroke="white" stroke-width="0.3" fill="none"/>`;
            }
          }

