        // Heartbeat for tension
        startHeartbeat(bpm = 80) {
          if (!this.initialized) return;

          const interval = 60000 / bpm;

          const beat = () => {
            // Two-beat heartbeat sound
            [0, 0.15].forEach((delay, i) => {
              const osc = this.ctx.createOscillator();
              osc.type = 'sine';
              osc.frequency.value = i === 0 ? 50 : 40;

              const gain = this.ctx.createGain();
              gain.gain.setValueAtTime(0, this.ctx.currentTime + delay);
              gain.gain.linearRampToValueAtTime(i === 0 ? 0.25 : 0.15, this.ctx.currentTime + delay + 0.02);
              gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + delay + 0.15);

              osc.connect(gain);
              gain.connect(this.masterGain);

              osc.start(this.ctx.currentTime + delay);
              osc.stop(this.ctx.currentTime + delay + 0.15);
            });
          };

          beat();
          this.heartbeatInterval = setInterval(beat, interval);
        },

