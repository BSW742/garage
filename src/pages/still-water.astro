      function showChoice(prompt, choices, timer, defaultChoice, flag) {
        return new Promise(resolve => {
          const container = document.getElementById('choices');
          container.innerHTML = '';

          choices.forEach((choice, i) => {
            const div = document.createElement('div');
            div.className = 'choice';
            div.innerHTML = `
              <span class="choice-key">${choice.key}</span>
              <span class="choice-text">${choice.text}</span>
              <div class="choice-timer" style="width: 100%"></div>
            `;
            div.dataset.consequence = choice.consequence;
            container.appendChild(div);
          });

          container.classList.add('visible');
          GameState.inChoice = true;

          let timeLeft = timer;
          const timerInterval = setInterval(() => {
            timeLeft -= 100;
            const percent = (timeLeft / timer) * 100;
            container.querySelectorAll('.choice-timer').forEach(t => {
              t.style.width = `${percent}%`;
              if (percent < 30) t.style.background = '#ef4444';
              else if (percent < 60) t.style.background = '#f59e0b';
            });

            if (timeLeft <= 0) {
              clearInterval(timerInterval);
              makeChoice(choices[defaultChoice].consequence);
            }
          }, 100);

          function makeChoice(consequence) {
            AudioEngine.playSelect();
            clearInterval(timerInterval);
            container.classList.remove('visible');
            GameState.inChoice = false;
            GameState.choices[flag] = consequence;
            GameState.flags[flag] = consequence;
            document.removeEventListener('keydown', handleKey);
            resolve(consequence);
          }

          function handleKey(e) {
            const choice = choices.find(c => c.key === e.key);
            if (choice) {
              makeChoice(choice.consequence);
            }
          }

          document.addEventListener('keydown', handleKey);

          // Click and hover handlers
          container.querySelectorAll('.choice').forEach(div => {
            div.onclick = () => makeChoice(div.dataset.consequence);
            div.onmouseenter = () => AudioEngine.playHover();
          });
        });
      }

      function showConsequence(text, isSuccess) {
        const el = document.getElementById('consequence');
        el.querySelector('.consequence-text').textContent = text;
        el.className = 'visible ' + (isSuccess ? 'success' : 'fail');
        setTimeout(() => el.className = '', 2000);
      }

      function showQTESingle(key, duration, prompt, successText, failText) {
        return new Promise(resolve => {
          const container = document.getElementById('qte-container');
          container.innerHTML = `
            <div class="qte-prompt">${prompt}</div>
            <div class="qte-key">${key}</div>
            <div class="qte-timer"><div class="qte-timer-fill" style="width: 100%"></div></div>
            <div class="qte-instruction">Press <strong>${key}</strong> quickly!</div>
          `;
          container.classList.add('visible');
          GameState.inQTE = true;

          const keyEl = container.querySelector('.qte-key');
          const timerFill = container.querySelector('.qte-timer-fill');

          let timeLeft = duration;
          let success = false;

          const timerInterval = setInterval(() => {
            timeLeft -= 50;
            const percent = (timeLeft / duration) * 100;
            timerFill.style.width = `${percent}%`;

            if (percent < 30) timerFill.classList.add('danger');
            else if (percent < 60) timerFill.classList.add('warning');

            if (timeLeft <= 0) {
              clearInterval(timerInterval);
              if (!success) {
                AudioEngine.playFail();
                keyEl.classList.add('fail');
                if (failText) showConsequence(failText, false);
                setTimeout(() => {
                  container.classList.remove('visible');
                  GameState.inQTE = false;
                  document.removeEventListener('keydown', handleKey);
                  resolve({ success: false, text: failText });
                }, 800);
              }
            }
          }, 50);

          function handleKey(e) {
            if (e.key.toUpperCase() === key || e.code === key) {
              success = true;
              AudioEngine.playSuccess();
              clearInterval(timerInterval);
              keyEl.classList.add('success');
              document.removeEventListener('keydown', handleKey);
              if (successText) showConsequence(successText, true);

              setTimeout(() => {
                container.classList.remove('visible');
                GameState.inQTE = false;
                resolve({ success: true, text: successText });
              }, 800);
            }
          }

          document.addEventListener('keydown', handleKey);
        });
      }

      function showQTEHold(key, duration, prompt, successFlag) {
        return new Promise(resolve => {
          const container = document.getElementById('qte-container');
          const displayKey = key === 'SPACE' ? 'SPACEBAR' : key;
          container.innerHTML = `
            <div class="qte-prompt">${prompt}</div>
            <div class="qte-hold-ring">
              <svg class="qte-hold-progress" viewBox="0 0 120 120">
                <circle cx="60" cy="60" r="56" fill="none" stroke="#4a9eff" stroke-width="4"
                  stroke-dasharray="352" stroke-dashoffset="352" transform="rotate(-90 60 60)"/>
              </svg>
              <div class="qte-hold-key">${key === 'SPACE' ? '␣' : key}</div>
            </div>
            <div class="qte-instruction">Hold <strong>${displayKey}</strong> until the ring fills!</div>
          `;
          container.classList.add('visible');
          GameState.inQTE = true;

          const circle = container.querySelector('circle');
          const circumference = 352;
          let progress = 0;
          let holding = false;
          let completed = false;

          function handleKeyDown(e) {
            if ((e.code === 'Space' && key === 'SPACE') || e.key.toUpperCase() === key) {
              holding = true;
            }
          }

          function handleKeyUp(e) {
            if ((e.code === 'Space' && key === 'SPACE') || e.key.toUpperCase() === key) {
              holding = false;
            }
          }

          document.addEventListener('keydown', handleKeyDown);
          document.addEventListener('keyup', handleKeyUp);

          const updateInterval = setInterval(() => {
            if (completed) return;

            if (holding) {
              progress += 2;
              if (progress >= 100) {
                progress = 100;
                completed = true;
                AudioEngine.playSuccess();
                clearInterval(updateInterval);
                document.removeEventListener('keydown', handleKeyDown);
                document.removeEventListener('keyup', handleKeyUp);
                GameState.flags[successFlag] = true;

                circle.style.stroke = '#4ade80';
                setTimeout(() => {
                  container.classList.remove('visible');
                  GameState.inQTE = false;
                  resolve(true);
                }, 500);
              }
            } else {
              progress -= 1;
              if (progress < 0) progress = 0;
            }

            const offset = circumference - (progress / 100) * circumference;
            circle.style.strokeDashoffset = offset;
          }, 30);

          // Timeout
          setTimeout(() => {
            if (!completed) {
              completed = true;
              AudioEngine.playFail();
              clearInterval(updateInterval);
              document.removeEventListener('keydown', handleKeyDown);
              document.removeEventListener('keyup', handleKeyUp);
              GameState.flags[successFlag] = false;

              circle.style.stroke = '#ef4444';
              setTimeout(() => {
                container.classList.remove('visible');
                GameState.inQTE = false;
                resolve(false);
              }, 500);
            }
          }, duration + 2000);
        });
      }

      function showQTESequence(keys, duration, prompt, successFlag) {
        return new Promise(resolve => {
          const container = document.getElementById('qte-container');
          container.innerHTML = `
            <div class="qte-prompt">${prompt}</div>
            <div class="qte-sequence">
              ${keys.map(k => `<div class="qte-seq-key">${k}</div>`).join('')}
            </div>
            <div class="qte-timer"><div class="qte-timer-fill" style="width: 100%"></div></div>
            <div class="qte-instruction">Press <strong>${keys.join(' → ')}</strong> in order!</div>
          `;
          container.classList.add('visible');
          GameState.inQTE = true;

          const keyEls = container.querySelectorAll('.qte-seq-key');
          const timerFill = container.querySelector('.qte-timer-fill');

          let currentIndex = 0;
          let timeLeft = duration;
          let completed = false;

          keyEls[0].classList.add('active');

          const timerInterval = setInterval(() => {
            timeLeft -= 50;
            const percent = (timeLeft / duration) * 100;
            timerFill.style.width = `${percent}%`;

            if (percent < 30) timerFill.classList.add('danger');
            else if (percent < 60) timerFill.classList.add('warning');

            if (timeLeft <= 0 && !completed) {
              completed = true;
              AudioEngine.playFail();
              clearInterval(timerInterval);
              document.removeEventListener('keydown', handleKey);

              keyEls.forEach((el, i) => {
                if (i >= currentIndex) el.classList.add('missed');
              });

              GameState.flags[successFlag] = false;

              setTimeout(() => {
                container.classList.remove('visible');
                GameState.inQTE = false;
                resolve(false);
              }, 500);
            }
          }, 50);

          function handleKey(e) {
            if (completed) return;

            if (e.key.toUpperCase() === keys[currentIndex]) {
              AudioEngine.playBlip();
              keyEls[currentIndex].classList.remove('active');
              keyEls[currentIndex].classList.add('done');
              currentIndex++;

              if (currentIndex >= keys.length) {
                completed = true;
                AudioEngine.playSuccess();
                clearInterval(timerInterval);
                document.removeEventListener('keydown', handleKey);
                GameState.flags[successFlag] = true;

                setTimeout(() => {
                  container.classList.remove('visible');
                  GameState.inQTE = false;
                  resolve(true);
                }, 500);
              } else {
                keyEls[currentIndex].classList.add('active');
              }
            }
          }

          document.addEventListener('keydown', handleKey);
        });
      }

      async function transition(duration) {
        AudioEngine.playWhoosh();
        const trans = document.getElementById('transition');
        trans.classList.add('active');
        hideDialogue();
        hideThought();
        hideCharIntro();
        hideTimestamp();
        hideSound();
        await sleep(duration);
        trans.classList.remove('active');
      }

      function hideDialogue() {
        document.getElementById('dialogue-container').classList.remove('visible');
        document.getElementById('continue-prompt').classList.remove('visible');
      }

      async function showChapterTitle() {
        const title = document.getElementById('chapter-title');
        title.classList.add('visible');
        await sleep(4000);
        title.classList.remove('visible');
      }

      async function showChapterEnd(text, subtext) {
        const container = document.getElementById('chapter-title');
        container.querySelector('.chapter-num').textContent = '';
        container.querySelector('.chapter-name').textContent = text;
        container.querySelector('.chapter-location').textContent = subtext;
        container.classList.add('visible');

        await sleep(5000);

        // Show choices/stats here eventually
        container.querySelector('.chapter-location').textContent = 'Press SPACE to continue...';

        await new Promise(resolve => {
          const handler = (e) => {
            if (e.code === 'Space') {
              document.removeEventListener('keydown', handler);
              resolve();
            }
          };
          document.addEventListener('keydown', handler);
        });

        container.classList.remove('visible');
      }

      // ============================================
      // Main Game Loop
      // ============================================

      async function processBeat(beat) {
        switch (beat.type) {
          case 'chapter-title':
            await showChapterTitle();
            break;

          case 'transition':
            await transition(beat.duration);
            break;

          case 'set-character':
            setCharacter(beat.character);
            break;

          case 'scene':
            setBackground(beat.bg);
            if (beat.timestamp) {
              showTimestamp(beat.timestamp.time, beat.timestamp.location);
            }
            await sleep(500);
            break;

          case 'char-intro':
            showCharIntro(beat.character);
            await sleep(beat.duration);
            hideCharIntro();
            break;

          case 'sound':
            showSound(beat.text);
            break;

          case 'narrative':
            await showNarrative(beat.text);
            break;

          case 'dialogue':
            hideThought();
            await showDialogue(beat.speaker, beat.text);
            break;

          case 'thought':
            showThought(beat.text);
            await sleep(100);
            break;

          case 'choice':
            hideThought();
            await showChoice(beat.prompt, beat.choices, beat.timer, beat.default, beat.flag);
            break;

          case 'branch':
            const branchValue = GameState.flags[beat.flag];
            const branchBeats = beat.branches[branchValue] || beat.branches[Object.keys(beat.branches)[0]];
            if (branchBeats) {
              for (const subBeat of branchBeats) {
                await processBeat(subBeat);
              }
            }
            break;

          case 'qte-single':
            hideThought();
            const singleResult = await showQTESingle(beat.key, beat.duration, beat.prompt, beat.success_text, beat.fail_text);
            if (singleResult.text) {
              await showNarrative(singleResult.text);
            }
            break;

          case 'qte-hold':
            hideThought();
            await showQTEHold(beat.key, beat.duration, beat.prompt, beat.success_flag);
            break;

          case 'qte-sequence':
            hideThought();
            await showQTESequence(beat.keys, beat.duration, beat.prompt, beat.success_flag);
            break;

          case 'tension-start':
            AudioEngine.startHeartbeat(beat.bpm || 80);
            AudioEngine.startDrone();
            break;

          case 'tension-stop':
            AudioEngine.stopHeartbeat();
            AudioEngine.stopDrone();
            break;

          case 'chapter-end':
            AudioEngine.stopHeartbeat();
            AudioEngine.stopDrone();
            await showChapterEnd(beat.text, beat.subtext);
            break;
        }
      }

      async function runChapter(chapter) {
        for (const beat of chapter) {
          await processBeat(beat);
        }
      }

      // Skip typing on any key
      document.addEventListener('keydown', (e) => {
        if (GameState.isTyping && !GameState.inQTE && !GameState.inChoice) {
          GameState.skipTyping = true;
        }
      });

      // Start the game
      runChapter(Chapter1);

      // Handle resize
      window.addEventListener('resize', () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      });
    </script>
  </body>
</html>
