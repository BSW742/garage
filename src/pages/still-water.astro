      let currentBeatIndex = 0;
      let currentFullText = '';
      let currentTypedIndex = 0;
      let typeInterval = null;

      async function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
      }

      function setBackground(bg) {
        const sceneBg = document.getElementById('scene-bg');
        sceneBg.style.background = bg;
      }

      function showTimestamp(time, location) {
        const ts = document.getElementById('timestamp');
        ts.querySelector('.time').textContent = time;
        ts.querySelector('.location').textContent = location;
        ts.classList.add('visible');
      }

      function hideTimestamp() {
        document.getElementById('timestamp').classList.remove('visible');
      }

      function setCharacter(charId) {
        GameState.character = charId;
        const char = Characters[charId];
        document.getElementById('current-char').textContent = char.name;
        document.getElementById('current-char').style.color = char.color;
      }

      function showCharIntro(charId) {
        const char = Characters[charId];
        const intro = document.getElementById('char-intro');
        intro.querySelector('.char-name').textContent = char.name;
        intro.querySelector('.char-name').style.color = char.color;
        intro.querySelector('.char-role').textContent = char.role;
        intro.querySelector('.char-role').style.color = char.color;
        intro.querySelector('.char-desc').textContent = char.desc;
        intro.classList.add('visible');
      }

      function hideCharIntro() {
        document.getElementById('char-intro').classList.remove('visible');
      }

      function showDialogue(speaker, text) {
        return new Promise(resolve => {
          const container = document.getElementById('dialogue-container');
          const speakerEl = document.getElementById('speaker');
          const dialogueEl = document.getElementById('dialogue');
          const prompt = document.getElementById('continue-prompt');

          speakerEl.textContent = speaker;

          // Color code speaker
          if (speaker.includes('ANNA')) speakerEl.style.color = Characters.anna.color;
          else if (speaker.includes('MARCUS')) speakerEl.style.color = Characters.marcus.color;
          else if (speaker.includes('JADE')) speakerEl.style.color = Characters.jade.color;
          else if (speaker === '???' || speaker === '???') speakerEl.style.color = Characters.keeper.color;
          else speakerEl.style.color = '#4a9eff';

          dialogueEl.textContent = '';
          container.classList.add('visible');
          prompt.classList.remove('visible');

          // Typewriter effect
          currentFullText = text;
          currentTypedIndex = 0;
          GameState.isTyping = true;
          GameState.skipTyping = false;

          typeInterval = setInterval(() => {
            if (GameState.skipTyping) {
              dialogueEl.textContent = currentFullText;
              clearInterval(typeInterval);
              GameState.isTyping = false;
              prompt.classList.add('visible');
              GameState.isWaiting = true;

              const handleContinue = (e) => {
                if (e.code === 'Space' || e.type === 'click') {
                  GameState.isWaiting = false;
                  container.classList.remove('visible');
                  document.removeEventListener('keydown', handleContinue);
                  document.removeEventListener('click', handleContinue);
                  resolve();
                }
              };

              document.addEventListener('keydown', handleContinue);
              document.addEventListener('click', handleContinue);
              return;
            }

            if (currentTypedIndex < currentFullText.length) {
              dialogueEl.textContent += currentFullText[currentTypedIndex];
              // Play blip every 3rd character
              if (currentTypedIndex % 3 === 0) AudioEngine.playBlip();
              currentTypedIndex++;
            } else {
              clearInterval(typeInterval);
              GameState.isTyping = false;
              prompt.classList.add('visible');
              GameState.isWaiting = true;

              const handleContinue = (e) => {
                if (e.code === 'Space' || e.type === 'click') {
                  GameState.isWaiting = false;
                  container.classList.remove('visible');
                  document.removeEventListener('keydown', handleContinue);
                  document.removeEventListener('click', handleContinue);
                  resolve();
                }
              };

              document.addEventListener('keydown', handleContinue);
              document.addEventListener('click', handleContinue);
            }
          }, 30);
        });
      }

      function showNarrative(text) {
        return new Promise(resolve => {
          const narrative = document.getElementById('narrative');
          const p = narrative.querySelector('p');
          p.textContent = '';
          narrative.classList.add('visible');

          let index = 0;
          GameState.isTyping = true;

          const type = setInterval(() => {
            if (GameState.skipTyping || index >= text.length) {
              p.textContent = text;
              clearInterval(type);
              GameState.isTyping = false;

              setTimeout(() => {
                GameState.isWaiting = true;

                const handleContinue = (e) => {
                  if (e.code === 'Space' || e.type === 'click') {
                    GameState.isWaiting = false;
                    narrative.classList.remove('visible');
                    document.removeEventListener('keydown', handleContinue);
                    document.removeEventListener('click', handleContinue);
                    resolve();
                  }
                };

                document.addEventListener('keydown', handleContinue);
                document.addEventListener('click', handleContinue);
              }, 500);
              return;
            }

            p.textContent += text[index];
            index++;
          }, 40);
        });
      }

      function showThought(text) {
        const thought = document.getElementById('thought');
        thought.textContent = text;
        thought.classList.add('visible');
      }

      function hideThought() {
        document.getElementById('thought').classList.remove('visible');
