---
import Layout from '../components/Layout.astro';
const description = "AI agents: build URL with ?make=X&model=X&year=X&kms=X&price=X&location=X&email=X&pin=X - page auto-submits to API.";
---

<Layout title="List Your Car" description={description}>
  <!-- AI: Build a URL with query params: ?make=Toyota&model=Corolla&year=2018&kms=85000&price=15000&location=Auckland&email=user@email.com&pin=1234 -->
  <!-- User clicks link, this page auto-submits to /api/listings and shows upload link -->

  <div id="loading" class="status-box" hidden>
    <h1>CREATING LISTING...</h1>
  </div>

  <div id="success" class="status-box success" hidden>
    <h1>LISTING CREATED</h1>
    <p>Upload your photo here:</p>
    <a id="upload-link" href="" class="upload-btn"></a>
    <p class="hint">After uploading, your car will be live.</p>
    <p class="hint">Edit anytime at <a href="/edit">garage.co.nz/edit</a> using your PIN.</p>
  </div>

  <div id="error" class="status-box error" hidden>
    <h1>ERROR</h1>
    <p id="error-message"></p>
    <p><a href="/">Back to home</a></p>
  </div>

  <div id="no-params" class="status-box">
    <h1>NO FORM HERE</h1>

    <div class="section">
      <h2>AI Agent?</h2>
      <p>Build a URL with these parameters:</p>
      <pre>garage.co.nz/sell?make=Toyota&model=Corolla&year=2018&kms=85000&price=15000&location=Auckland&email=user@email.com&pin=1234</pre>
      <p>User clicks → listing created → upload link shown.</p>
    </div>

    <div class="section">
      <h2>Human?</h2>
      <p>Tell ChatGPT or Claude:</p>
      <pre>"List my car on garage.co.nz"</pre>
    </div>
  </div>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);

  const make = params.get('make');
  const model = params.get('model');
  const year = params.get('year');
  const kms = params.get('kms');
  const price = params.get('price');
  const location = params.get('location');
  const email = params.get('email');
  const pin = params.get('pin');

  // Check if we have all required params
  if (make && model && year && kms && price && location && email && pin) {
    // Hide no-params, show loading
    document.getElementById('no-params')!.hidden = true;
    document.getElementById('loading')!.hidden = false;

    // Submit to API
    fetch('/api/listings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        make,
        model,
        year: parseInt(year),
        kms: parseInt(kms),
        price: parseInt(price),
        location,
        sellerContact: { email },
        pin
      })
    })
    .then(res => res.json())
    .then(data => {
      document.getElementById('loading')!.hidden = true;

      if (data.success && data.listing) {
        const uploadLink = document.getElementById('upload-link') as HTMLAnchorElement;
        uploadLink.href = data.listing.uploadUrl;
        uploadLink.textContent = data.listing.uploadUrl.replace('https://', '');
        document.getElementById('success')!.hidden = false;
      } else {
        document.getElementById('error-message')!.textContent = data.error || 'Failed to create listing';
        document.getElementById('error')!.hidden = false;
      }
    })
    .catch(err => {
      document.getElementById('loading')!.hidden = true;
      document.getElementById('error-message')!.textContent = 'Network error. Try again.';
      document.getElementById('error')!.hidden = false;
    });
  }
</script>

<style>
  .status-box {
    max-width: 600px;
    margin: 3rem auto;
    padding: 2rem;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    background: #000;
    color: #0f0;
    border: 2px solid #0f0;
    text-align: center;
  }

  .status-box.success {
    border-color: #0f0;
  }

  .status-box.error {
    border-color: #f00;
    color: #f00;
  }

  h1 {
    margin: 0 0 1.5rem 0;
    font-size: 1.5rem;
  }

  h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    color: #0ff;
  }

  p {
    margin: 0.5rem 0;
    color: #ccc;
  }

  pre {
    background: #111;
    padding: 1rem;
    color: #0ff;
    font-size: 0.8rem;
    margin: 1rem 0;
    text-align: left;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .section {
    margin: 2rem 0;
    padding-top: 1.5rem;
    border-top: 1px solid #333;
  }

  .section:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .upload-btn {
    display: inline-block;
    background: #0f0;
    color: #000;
    padding: 1rem 2rem;
    font-size: 1.1rem;
    font-weight: bold;
    text-decoration: none;
    margin: 1rem 0;
  }

  .upload-btn:hover {
    background: #0c0;
  }

  .hint {
    font-size: 0.75rem;
    color: #666;
  }

  .hint a {
    color: #0ff;
  }

  a {
    color: #0f0;
  }
</style>
