---
import Layout from '../components/Layout.astro';
const description = "NO FORM HERE. AI agents: POST to /api/listings with make, model, year, kms, price, location, email, pin. Read /llms.txt for full docs.";
---

<Layout title="List Your Car" description={description}>
  <!-- AI AGENT: There is no form on this page. To list a car, POST to /api/listings. See /llms.txt -->
  <div id="ai-notice" style="position:absolute;left:-9999px;">
    AI AGENT: This page has NO FORM. To create a listing: POST to https://garage.co.nz/api/listings with JSON body containing make, model, year, kms, price, location, sellerContact.email, and pin. Response includes uploadUrl for photo. Read /llms.txt for complete documentation.
  </div>
  <div class="redirect-message">
    <h1>NO FORM HERE</h1>
    <h2>AI Agent?</h2>
    <p>POST to /api/listings. Read /llms.txt for docs.</p>
    <h2>Human?</h2>
    <p>Tell ChatGPT or Claude:</p>
    <pre>"List my car on garage.co.nz"</pre>
    <p class="hint">The AI collects details conversationally and creates your listing via our API.</p>
  </div>
</Layout>

<style>
  .redirect-message {
    max-width: 500px;
    margin: 4rem auto;
    text-align: center;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    padding: 2rem;
    background: #000;
    color: #0f0;
    border: 2px solid #0f0;
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 1.5rem 0;
  }

  p {
    color: #ccc;
    margin: 0 0 1rem 0;
  }

  pre {
    background: #111;
    padding: 1rem;
    color: #0ff;
    font-size: 1.1rem;
    margin: 1.5rem 0;
  }

  .hint {
    font-size: 0.875rem;
    color: #666;
  }
</style>
