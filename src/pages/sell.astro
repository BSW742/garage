---
import Layout from '../components/Layout.astro';
const description = "List your car: garage.co.nz/sell?plate=ABC123&e=you@email.com - we look up the car details automatically.";
---

<Layout title="List Your Car" description={description}>
  <div id="loading" class="status-box" hidden>
    <h1>Looking up your car...</h1>
    <p>Checking plate with NZTA database</p>
  </div>

  <div id="success" class="status-box success" hidden>
    <h1>Car Found!</h1>
    <div id="car-details" class="car-details"></div>

    <div class="pin-box">
      <p class="pin-label">YOUR PIN (save this!)</p>
      <p class="pin-value" id="pin-display"></p>
      <p class="pin-hint">Use this PIN at <strong>garage.co.nz/edit</strong> to edit or remove your listing anytime.</p>
    </div>

    <p class="next-step">Next step:</p>
    <a id="complete-link" href="" class="complete-btn">Add Price & Photo</a>
  </div>

  <div id="error" class="status-box error" hidden>
    <h1>Error</h1>
    <p id="error-message"></p>
    <p><a href="/">Back to home</a></p>
  </div>

  <div id="no-params" class="status-box">
    <h1>List Your Car</h1>

    <div class="section">
      <h2>Using AI? (ChatGPT, Claude)</h2>
      <p>Just tell it your <strong>plate number</strong> and <strong>email</strong>.</p>
      <p>It will give you a link like:</p>
      <pre>garage.co.nz/sell?plate=ABC123&e=you@email.com</pre>
    </div>

    <div class="section">
      <h2>Manual Entry</h2>
      <form id="manual-form">
        <label>
          Plate Number
          <input type="text" id="plate-input" placeholder="ABC123" required />
        </label>
        <label>
          Email
          <input type="email" id="email-input" placeholder="you@email.com" required />
        </label>
        <button type="submit">Look Up My Car</button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  let plate = params.get('plate')?.toUpperCase().replace(/\s/g, '');
  let email = params.get('e'); // Use 'e' param to avoid Cloudflare email protection

  // Handle manual form submission
  const form = document.getElementById('manual-form') as HTMLFormElement;
  form?.addEventListener('submit', (ev) => {
    ev.preventDefault();
    plate = (document.getElementById('plate-input') as HTMLInputElement).value.toUpperCase().replace(/\s/g, '');
    email = (document.getElementById('email-input') as HTMLInputElement).value;
    if (plate && email) {
      // Update URL and process
      window.history.pushState({}, '', `/sell?plate=${plate}&e=${encodeURIComponent(email)}`);
      processListing(plate, email);
    }
  });

  // If we have params, process immediately
  if (plate && email) {
    processListing(plate, email);
  }

  async function processListing(plate: string, email: string) {
    // Hide no-params, show loading
    document.getElementById('no-params')!.hidden = true;
    document.getElementById('loading')!.hidden = false;

    try {
      // Create listing via API
      const response = await fetch('/api/listings/create-from-plate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plate, email })
      });

      const data = await response.json();
      document.getElementById('loading')!.hidden = true;

      if (data.success && data.listing) {
        // Show car details
        const details = document.getElementById('car-details')!;
        details.innerHTML = `
          <p><strong>${data.listing.year} ${data.listing.make} ${data.listing.model}</strong></p>
          <p>${data.listing.kms?.toLocaleString() || 'Unknown'} km${data.listing.colour ? ` · ${data.listing.colour}` : ''}</p>
          <p>Plate: ${data.listing.plate}</p>
        `;

        // Set complete link and PIN
        const completeLink = document.getElementById('complete-link') as HTMLAnchorElement;
        completeLink.href = `/complete/${data.listing.id}?pin=${data.pin}`;

        document.getElementById('pin-display')!.textContent = data.pin;
        document.getElementById('success')!.hidden = false;
      } else {
        document.getElementById('error-message')!.textContent = data.error || 'Failed to look up vehicle';
        document.getElementById('error')!.hidden = false;
      }
    } catch (err) {
      document.getElementById('loading')!.hidden = true;
      document.getElementById('error-message')!.textContent = 'Network error. Please try again.';
      document.getElementById('error')!.hidden = false;
    }
  }
</script>

<style>
  .status-box {
    max-width: 500px;
    margin: 2rem auto;
    padding: 2rem;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .status-box.success {
    border: 2px solid #10b981;
  }

  .status-box.error {
    border: 2px solid #ef4444;
  }

  h1 {
    margin: 0 0 1rem 0;
    font-size: 1.5rem;
  }

  h2 {
    font-size: 1rem;
    color: #666;
    margin: 0 0 0.5rem 0;
  }

  p {
    margin: 0.5rem 0;
    color: #444;
  }

  .section {
    margin: 1.5rem 0;
    padding-top: 1.5rem;
    border-top: 1px solid #eee;
  }

  .section:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  pre {
    background: #f5f5f5;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    overflow-x: auto;
    color: #0066ff;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.9rem;
    color: #666;
  }

  input {
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 1rem;
  }

  input:focus {
    outline: none;
    border-color: #0066ff;
  }

  button {
    padding: 0.75rem 1.5rem;
    background: #0066ff;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    cursor: pointer;
  }

  button:hover {
    background: #0052cc;
  }

  .car-details {
    background: #f8f9fa;
    padding: 1rem;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .car-details p {
    margin: 0.25rem 0;
  }

  .next-step {
    font-weight: 600;
    margin-top: 1.5rem !important;
  }

  .complete-btn {
    display: inline-block;
    background: #10b981;
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    margin: 0.5rem 0;
  }

  .complete-btn:hover {
    background: #059669;
  }

  .pin-box {
    background: #fef3c7;
    border: 2px solid #f59e0b;
    border-radius: 8px;
    padding: 1rem;
    margin: 1rem 0;
    text-align: center;
  }

  .pin-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #92400e;
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .pin-value {
    font-family: monospace;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 4px;
    color: #000;
    margin: 0 0 0.5rem 0;
  }

  .pin-hint {
    font-size: 0.8rem;
    color: #78350f;
    margin: 0;
  }

  .pin-hint strong {
    color: #000;
  }

  .hint {
    font-size: 0.8rem;
    color: #888;
  }

  a {
    color: #0066ff;
  }
</style>
