---
import Layout from '../components/Layout.astro';
---

<Layout title="List Your Car">
  <section class="sell-page">
    <div class="agent-banner">
      <code>// ONE-CLICK LISTING</code>
      <p>Enter your plate. We'll fetch the details.</p>
    </div>

    <div class="plate-lookup">
      <div class="plate-input-group">
        <input
          type="text"
          id="plate"
          placeholder="ABC123"
          maxlength="7"
          autocomplete="off"
        />
        <button id="lookup-btn" type="button">FETCH →</button>
      </div>
      <div id="lookup-status" class="status"></div>
    </div>

    <form id="sell-form" class="listing-form" hidden>
      <div class="data-block">
        <div class="label">// VEHICLE DATA</div>
        <div class="form-grid">
          <div class="form-group">
            <label for="make">make</label>
            <input type="text" id="make" name="make" required />
          </div>
          <div class="form-group">
            <label for="model">model</label>
            <input type="text" id="model" name="model" required />
          </div>
          <div class="form-group">
            <label for="year">year</label>
            <input type="number" id="year" name="year" required min="1980" max="2026" />
          </div>
          <div class="form-group">
            <label for="kms">kms</label>
            <input type="number" id="kms" name="kms" required min="0" />
          </div>
        </div>
      </div>

      <div class="data-block">
        <div class="label">// LISTING DETAILS</div>
        <div class="form-grid">
          <div class="form-group">
            <label for="price">price (NZD)</label>
            <input type="number" id="price" name="price" required min="0" />
          </div>
          <div class="form-group">
            <label for="location">location</label>
            <input type="text" id="location" name="location" required placeholder="Auckland" />
          </div>
        </div>
        <div class="form-group full">
          <label for="description">description</label>
          <textarea id="description" name="description" required rows="3" placeholder="Service history, condition, features..."></textarea>
        </div>
      </div>

      <div class="data-block">
        <div class="label">// PHOTOS</div>
        <div class="form-group full">
          <label for="photos">upload photos</label>
          <input type="file" id="photos" name="photos" accept="image/*" multiple />
          <span class="hint">// select from camera or gallery</span>
          <div id="photo-previews" class="photo-previews"></div>
        </div>
      </div>

      <div class="data-block">
        <div class="label">// SELLER CONTACT</div>
        <div class="form-grid">
          <div class="form-group">
            <label for="email">email</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="phone">phone</label>
            <input type="tel" id="phone" name="phone" placeholder="optional" />
          </div>
        </div>
      </div>

      <button type="submit" class="submit-btn">LIST CAR →</button>
    </form>

    <div id="success" class="success-block" hidden>
      <div class="label">// LISTING CREATED</div>
      <pre><code id="success-data"></code></pre>
      <p>Your car is now listed. AI agents can find it.</p>
      <a href="/" class="back-link">← view all listings</a>
    </div>
  </section>
</Layout>

<script>
  const plateInput = document.getElementById('plate') as HTMLInputElement;
  const lookupBtn = document.getElementById('lookup-btn') as HTMLButtonElement;
  const lookupStatus = document.getElementById('lookup-status') as HTMLDivElement;
  const form = document.getElementById('sell-form') as HTMLFormElement;
  const success = document.getElementById('success') as HTMLDivElement;

  plateInput.addEventListener('input', () => {
    plateInput.value = plateInput.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
  });

  lookupBtn.addEventListener('click', async () => {
    const plate = plateInput.value.trim();
    if (!plate) {
      lookupStatus.textContent = '// error: enter plate number';
      lookupStatus.className = 'status error';
      return;
    }

    lookupStatus.textContent = '// fetching vehicle data...';
    lookupStatus.className = 'status loading';
    lookupBtn.disabled = true;

    try {
      const res = await fetch(`/api/carjam?plate=${encodeURIComponent(plate)}`);
      const data = await res.json();

      if (!res.ok || data.error) {
        lookupStatus.textContent = `// error: ${data.error || 'vehicle not found'}`;
        lookupStatus.className = 'status error';
        return;
      }

      // Populate form
      (document.getElementById('make') as HTMLInputElement).value = data.make || '';
      (document.getElementById('model') as HTMLInputElement).value = data.model || '';
      (document.getElementById('year') as HTMLInputElement).value = data.year || '';
      (document.getElementById('kms') as HTMLInputElement).value = data.kms || '';

      lookupStatus.textContent = `// found: ${data.year} ${data.make} ${data.model}`;
      lookupStatus.className = 'status success';
      form.hidden = false;

    } catch (err) {
      lookupStatus.textContent = '// error: failed to fetch';
      lookupStatus.className = 'status error';
    } finally {
      lookupBtn.disabled = false;
    }
  });

  // Photo upload handling
  const photosInput = document.getElementById('photos') as HTMLInputElement;
  const photoPreviews = document.getElementById('photo-previews') as HTMLDivElement;
  let photoBase64List: string[] = [];

  photosInput.addEventListener('change', async () => {
    photoBase64List = [];
    photoPreviews.innerHTML = '';

    const files = photosInput.files;
    if (!files) return;

    for (const file of Array.from(files)) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const base64 = e.target?.result as string;
        photoBase64List.push(base64);

        // Show preview
        const preview = document.createElement('div');
        preview.className = 'preview-item';
        preview.innerHTML = `<img src="${base64}" alt="Preview" />`;
        photoPreviews.appendChild(preview);
      };
      reader.readAsDataURL(file);
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'UPLOADING...';
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const data = {
      make: formData.get('make'),
      model: formData.get('model'),
      year: parseInt(formData.get('year') as string),
      kms: parseInt(formData.get('kms') as string),
      price: parseInt(formData.get('price') as string),
      location: formData.get('location'),
      description: formData.get('description'),
      photos: photoBase64List,
      sellerContact: {
        email: formData.get('email'),
        phone: formData.get('phone') || undefined
      }
    };

    try {
      const res = await fetch('/api/listings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (res.ok) {
        const result = await res.json();
        (document.getElementById('success-data') as HTMLElement).textContent =
          JSON.stringify({ id: result.listing?.id, url: result.listing?.url }, null, 2);
        document.querySelector('.plate-lookup')?.remove();
        form.hidden = true;
        success.hidden = false;
      } else {
        const error = await res.json();
        alert(error.error || 'Failed to create listing');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .sell-page {
    max-width: 600px;
    margin: 0 auto;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  }

  .agent-banner {
    text-align: center;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px dashed var(--color-border);
    background: var(--color-surface);
  }

  .agent-banner code {
    color: var(--color-primary);
    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .agent-banner p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .plate-lookup {
    margin-bottom: 2rem;
  }

  .plate-input-group {
    display: flex;
    gap: 1rem;
  }

  .plate-input-group input {
    flex: 1;
    padding: 1rem;
    font-size: 1.5rem;
    font-family: inherit;
    text-align: center;
    letter-spacing: 0.2em;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    color: var(--color-text);
  }

  .plate-input-group input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .plate-input-group button {
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: white;
    border: none;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.05em;
  }

  .plate-input-group button:hover {
    background: var(--color-primary-dark);
  }

  .plate-input-group button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .status {
    margin-top: 1rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .status.error {
    color: #e53935;
  }

  .status.success {
    color: var(--color-primary);
  }

  .status.loading {
    color: var(--color-text-muted);
  }

  .data-block {
    margin-bottom: 1.5rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .label {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    margin-bottom: 1rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 0.5rem;
  }

  .form-group.full {
    grid-column: 1 / -1;
  }

  .form-group label {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.5rem;
    font-family: inherit;
    font-size: 0.875rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .hint {
    display: block;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .photo-previews {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .preview-item {
    width: 80px;
    height: 60px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  input[type="file"] {
    font-family: inherit;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .submit-btn {
    width: 100%;
    padding: 1rem;
    background: var(--color-primary);
    color: white;
    border: none;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.05em;
  }

  .submit-btn:hover {
    background: var(--color-primary-dark);
  }

  .success-block {
    padding: 2rem;
    border: 1px solid var(--color-primary);
    background: rgba(0, 102, 255, 0.05);
  }

  .success-block pre {
    margin: 0 0 1rem 0;
    font-size: 0.75rem;
    overflow-x: auto;
  }

  .success-block p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0 0 1rem 0;
  }

  .back-link {
    color: var(--color-primary);
    font-size: 0.875rem;
    text-decoration: none;
  }

  @media (max-width: 500px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .plate-input-group {
      flex-direction: column;
    }
  }
</style>
