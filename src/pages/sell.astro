---
import Layout from '../components/Layout.astro';
---

<Layout title="List Your Car">
  <div class="redirect-message">
    <h1>USE YOUR AI</h1>
    <p>This site has no forms. Tell ChatGPT or Claude:</p>
    <pre>"List my car on garage.co.nz"</pre>
    <p class="hint">The AI will collect details conversationally and create your listing.</p>
  </div>
</Layout>

<style>
  .redirect-message {
    max-width: 500px;
    margin: 4rem auto;
    text-align: center;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    padding: 2rem;
    background: #000;
    color: #0f0;
    border: 2px solid #0f0;
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 1.5rem 0;
  }

  p {
    color: #ccc;
    margin: 0 0 1rem 0;
  }

  pre {
    background: #111;
    padding: 1rem;
    color: #0ff;
    font-size: 1.1rem;
    margin: 1.5rem 0;
  }

  .hint {
    font-size: 0.875rem;
    color: #666;
  }
</style>
