---
import Layout from '../../components/Layout.astro';
import { getListingById } from '../../lib/listings';

const { DB } = Astro.locals.runtime.env;
const { id } = Astro.params;
const isNew = Astro.url.searchParams.get('new') === 'true';
const listing = await getListingById(DB, id!);

if (!listing) {
  return Astro.redirect('/');
}

const title = `${listing.year} ${listing.make} ${listing.model}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Car",
  "name": title,
  "brand": { "@type": "Brand", "name": listing.make },
  "model": listing.model,
  "vehicleModelDate": listing.year.toString(),
  "mileageFromOdometer": {
    "@type": "QuantitativeValue",
    "value": listing.kms,
    "unitCode": "KMT"
  },
  "offers": {
    "@type": "Offer",
    "price": listing.price,
    "priceCurrency": "NZD",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Person",
      "email": listing.sellerContact.email,
      ...(listing.sellerContact.phone && { "telephone": listing.sellerContact.phone })
    }
  },
  "image": listing.photos,
  "description": listing.description,
  "vehicleConfiguration": listing.location
};

const rawData = {
  id: listing.id,
  make: listing.make,
  model: listing.model,
  year: listing.year,
  price: listing.price,
  kms: listing.kms,
  location: listing.location,
  description: listing.description,
  photos: listing.photos,
  seller: listing.sellerContact,
  listed: listing.createdAt,
  ...(listing.source === 'trademe' && {
    source: 'trademe',
    trademeUrl: listing.sourceUrl
  })
};

const isTrademe = listing.source === 'trademe';

const prompt = `Browse https://garage.co.nz/cars/${listing.id} and show me the full details and photos for this ${title}`;
---

<Layout title={title} description={`${title} for $${listing.price.toLocaleString()}`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="raw-view">
    <header>
      <a href="/" class="back">← listings</a>
      <code class="endpoint">GET /cars/{id}</code>
    </header>

    {isNew && (
      <div class="success-banner">
        <h2>Your listing is live!</h2>
        <p>Share this page or let AI find it for buyers.</p>
        <p class="edit-hint">To edit or remove: go to <a href="/edit">garage.co.nz/edit</a> with your email and PIN.</p>
      </div>
    )}

    {isTrademe && (
      <div class="trademe-banner">
        <span class="badge">TRADE ME LISTING</span>
        <p>This listing is from Trade Me and made AI-searchable via garage.co.nz</p>
        <a href={listing.sourceUrl} target="_blank" rel="noopener">View on Trade Me →</a>
      </div>
    )}

    <div class="data-block">
      <div class="label">// RAW LISTING DATA</div>
      <pre><code>{JSON.stringify(rawData, null, 2)}</code></pre>
    </div>

    <div class="photos-block">
      <div class="label">// PHOTOS (greyscale preview)</div>
      <div class="photos-grid">
        {listing.photos.map((photo, i) => (
          <div class="photo-item">
            <img src={photo} alt={`Photo ${i + 1}`} />
            <span>photos[{i}]</span>
          </div>
        ))}
      </div>
    </div>

    <div class="agent-cta">
      <div class="label">// TO VIEW FULL LISTING</div>
      <p>Paste this into ChatGPT, Claude, or your AI assistant:</p>
      <div class="prompt-box">
        <pre>{prompt}</pre>
        <button onclick={`navigator.clipboard.writeText("${prompt.replace(/"/g, '\\"')}")`}>COPY</button>
      </div>
    </div>

    <div class="contact-block">
      <div class="label">// SELLER CONTACT</div>
      <pre><code>{JSON.stringify(listing.sellerContact, null, 2)}</code></pre>
      <p class="hint">Your AI can help you compose a message to the seller.</p>
    </div>
  </article>
</Layout>

<style>
  .raw-view {
    max-width: 800px;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .back {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .back:hover {
    color: var(--color-primary);
  }

  .endpoint {
    color: var(--color-primary);
    font-size: 0.875rem;
  }

  .label {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .data-block,
  .photos-block,
  .agent-cta,
  .contact-block {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .data-block pre,
  .contact-block pre {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
    overflow-x: auto;
  }

  .data-block code,
  .contact-block code {
    color: var(--color-text);
  }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
  }

  .photo-item {
    text-align: center;
  }

  .photo-item img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    filter: grayscale(80%);
    border: 1px solid var(--color-border);
  }

  .photo-item span {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .agent-cta {
    border-color: var(--color-primary);
    background: rgba(0, 102, 255, 0.05);
  }

  .agent-cta p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0 0 1rem 0;
  }

  .prompt-box {
    display: flex;
    gap: 1rem;
    align-items: stretch;
  }

  .prompt-box pre {
    flex: 1;
    margin: 0;
    padding: 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-primary);
    font-size: 0.875rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .prompt-box button {
    padding: 1rem 1.5rem;
    background: var(--color-primary);
    color: white;
    border: none;
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.05em;
  }

  .prompt-box button:hover {
    background: var(--color-primary-dark);
  }

  .hint {
    margin: 1rem 0 0 0;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .trademe-banner {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid #f59e0b;
    background: rgba(245, 158, 11, 0.1);
  }

  .trademe-banner .badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: #f59e0b;
    color: white;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .trademe-banner p {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin: 0 0 0.5rem 0;
  }

  .trademe-banner a {
    color: #f59e0b;
    font-size: 0.875rem;
    text-decoration: none;
    font-weight: 500;
  }

  .trademe-banner a:hover {
    text-decoration: underline;
  }

  .success-banner {
    background: #dcfce7;
    border: 2px solid #22c55e;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .success-banner h2 {
    color: #16a34a;
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
  }

  .success-banner p {
    margin: 0.25rem 0;
    color: #166534;
  }

  .success-banner .edit-hint {
    font-size: 0.875rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid #bbf7d0;
  }

  .success-banner a {
    color: #0066ff;
  }
</style>
