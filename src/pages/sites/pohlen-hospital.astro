    <meta name="description" content="POHLEN Hospital" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
      :root {
        --primary: #2563eb;
        --secondary: #1e3a5f;
        --accent: #f59e0b;
        --bg: #ffffff;
        --bg-alt: #f8fafc;
        --text: #1a1a1a;
        --text-muted: #666666;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* Utility */
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* Navigation */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        padding: 20px 0;
        transition: all 0.3s ease;
      }

      nav.scrolled {
